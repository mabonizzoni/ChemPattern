Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "lda", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"applyfunc", "\[Rule]", "Standardize"}], ",", 
      RowBox[{"output", "\[Rule]", "\"\<2DL\>\""}], ",", 
      RowBox[{"ellipsoidcolor", "\[Rule]", "Automatic"}], ",", 
      RowBox[{"swapaxes", "\[Rule]", "False"}], ",", 
      RowBox[{"confidencelevel", "->", "0.95"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lda", "::", "outputoptions"}], "=", 
   "\"\<The value `1` is not a valid plotting option. Valid options are: \
\\\"2DL\\\" (default), \\\"2D\\\", \\\"3DL\\\", \\\"3D\\\", \\\"scores\\\", \
\\\"eigenvectors\\\", \\\"eigensystem\\\", \\\"vartable\\\", \\\"varlist\\\".\
\>\""}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"lda", "::", "swapaxesnotboolean"}], "=", 
   "\"\<The value `1` is not a valid swapaxes option. Use only True / False \
or combinations thereof.\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lda", "::", "swapaxeslength"}], "=", 
   "\"\<The value `1` given for the swapaxes option is not valid. Acceptable \
values are a single True / False, to be applied to all axes, or a list \
containing as many True/False values as there are axes in the requested plot.\
\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lda", "::", "ellcolor"}], "=", 
   "\"\<The value `1` for the ellipsoidcolor option is not valid. Acceptable \
values are: Automatic, True, False. Automatic settings were used.\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"lda", "::", "conflevel"}], "=", 
    "\"\<`1` is an invalid value for the confidence level (0 < p < 1). The \
default 95% confidence level will be used instead.\>\""}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lda", "[", 
    RowBox[{
     RowBox[{"matrix_", "?", "MatrixQ"}], ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "the", " ", "definition", " ", "below", " ", "is", " ", "important"}],
         ",", " ", 
        RowBox[{"although", " ", "it", " ", "looks", " ", 
         RowBox[{"silly", "!"}]}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "If", " ", "one", " ", "used", " ", "matrix", " ", "directly", " ", 
         "in", " ", "the", " ", "function", " ", "body"}], ",", " ", 
        RowBox[{
        "the", " ", "VALUE", " ", "of", " ", "matrix", " ", "would", " ", 
         "be", " ", "substituted"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"everywhere", " ", "BEFORE", " ", "any", " ", "further", " ", 
        RowBox[{"evaluation", ".", " ", "the"}], " ", "name", " ", "of", " ", 
        "the", " ", "pattern", " ", "is", " ", "not", " ", "a", " ", "proper",
         " ", 
        RowBox[{"variable", "!!"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "This", " ", "is", " ", "the", " ", "reason", " ", "why", " ", "the", 
        " ", "standardization", " ", "in", " ", "place", " ", "did", " ", 
        "not", " ", "work", " ", "before"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"dataset", "=", "matrix"}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"other", " ", "local", " ", "variables"}], "*)"}], 
       "\[IndentingNewLine]", "hascolumnheaders", ",", "columnheaderlist", 
       ",", "classlist", ",", "\[IndentingNewLine]", "partitioneddata", ",", 
       "transformeddata", ",", "labeledtransformed", ",", "partitionedscores",
        ",", "\[IndentingNewLine]", "grandmean", ",", "clustermeans", ",", 
       "Swi", ",", "Sw", ",", "Sb", ",", "\[IndentingNewLine]", "eigenvals", 
       ",", "eigenvecs", ",", "\[IndentingNewLine]", "plotdata", ",", 
       "readyforplot", ",", "\[IndentingNewLine]", "confidenceLevel", ",", 
       "\[IndentingNewLine]", "ellipsoids2D", ",", "coloredellipsoids2D", ",",
        "\[IndentingNewLine]", "ellipsoids3D", ",", "coloredellipsoids3D", 
       ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "this", " ", "longer", " ", "color", " ", "list", " ", "was", " ", 
          "introduced", " ", "when", " ", "I", " ", "ran", " ", "the", " ", 
          "acetate", " ", "and", " ", "chloride", " ", "LDA"}], ",", " ", 
         RowBox[{
         "which", " ", "had", " ", "many", " ", "groups", " ", "and", " ", 
          "the", " ", "function", " ", "ran", " ", "out", " ", "of", " ", 
          "colors"}]}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"colorlist", "=", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"ColorData", "[", 
           RowBox[{"97", ",", "\"\<ColorList\>\""}], "]"}], ",", 
          RowBox[{"Lighter", "@", 
           RowBox[{"ColorData", "[", 
            RowBox[{"97", ",", "\"\<ColorList\>\""}], "]"}]}], ",", 
          RowBox[{"Lighter", "@", 
           RowBox[{"ColorData", "[", 
            RowBox[{"99", ",", "\"\<ColorList\>\""}], "]"}]}]}], "]"}]}]}], 
      "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Set", " ", "the", " ", "confidence", " ", "level", " ", "for", " ", 
       "ellipsoid", " ", "plotting"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "The", " ", "deafult", " ", "value", " ", "is", " ", "0.95", " ", "for",
        " ", "95", "%", " ", "confidence"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "Incorrect", " ", "values", " ", "trigger", " ", "a", " ", "message"}],
        ",", " ", 
       RowBox[{
       "but", " ", "the", " ", "calculation", " ", "continues", " ", 
        "anyway"}], ",", " ", 
       RowBox[{
       "using", " ", "the", " ", "default", " ", "95", "%", " ", "confidence",
         " ", "level"}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"confidenceLevel", "=", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"cf", "=", 
           RowBox[{"OptionValue", "[", "\"\<confidencelevel\>\"", "]"}]}], 
          "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"NumericQ", "[", "cf", "]"}], "&&", 
            RowBox[{"0", "<", "cf", "<", "1"}]}], ",", "cf", ",", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{
              RowBox[{"lda", "::", "conflevel"}], ",", "cf"}], "]"}], ";", 
            "0.95"}]}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "if", " ", "column", " ", "headers", " ", "are", " ", "present"}], 
        ",", " ", 
        RowBox[{
        "extract", " ", "them", " ", "and", " ", "assign", " ", "them", " ", 
         "to", " ", 
         RowBox[{"columnheaderlist", "."}]}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"if", " ", "not"}], ",", " ", 
        RowBox[{
        "create", " ", "a", " ", "generic", " ", "columnheaderlist", " ", 
         "and", " ", "add", " ", "it", " ", "to", " ", "the", " ", "top", " ",
          "of", " ", "the", " ", "dataset"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "this", " ", "simplifies", " ", "manipulation", " ", "later", " ", 
        "on", " ", "because", " ", "we", " ", "can", " ", "assume", " ", 
        "the", " ", "presence", " ", "of", " ", "column", " ", "headers"}], 
       " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"and", " ", 
         RowBox[{"don", "'"}], "t", " ", "need", " ", "to", " ", "repeatedly",
          " ", "check"}], ",", " ", 
        RowBox[{
        "no", " ", "matter", " ", "whether", " ", "the", " ", "original", " ",
          "data", " ", "had", " ", "them", " ", "or", " ", "not"}]}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Remember", " ", "that", " ", "from", " ", "now", " ", "on", " ", 
        RowBox[{"dataset", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}], " ", "contains", " ", "no", 
        " ", "intereseting", " ", "data"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"VectorQ", "[", 
          RowBox[{
           RowBox[{"dataset", "\[LeftDoubleBracket]", 
            RowBox[{"1", ",", 
             RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}], ",", 
           "NumberQ"}], "]"}], "\[Equal]", "True"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"hascolumnheaders", "=", "False"}], ";", 
         RowBox[{"PrependTo", "[", 
          RowBox[{"dataset", ",", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"{", "\"\<\>\"", "}"}], ",", 
             RowBox[{"columnheaderlist", "=", 
              RowBox[{"ToString", "/@", 
               RowBox[{"Array", "[", 
                RowBox[{"\"\<var\>\"", ",", 
                 RowBox[{
