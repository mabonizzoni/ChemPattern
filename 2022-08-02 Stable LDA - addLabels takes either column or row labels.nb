Cell[CellGroupData[{

Cell["Steps accomplished by the code below, in order:", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.6358844131307592`*^9, 3.6358844259074903`*^9}, {
  3.6375137196284943`*^9, 3.637513721219697*^9}, {3.752422545708048*^9, 
