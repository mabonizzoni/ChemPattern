Cell[CellGroupData[{

Cell["pairwiseScatterPlots:", "Section",
 CellChangeTimes->{{3.752422650090227*^9, 3.7524226872272835`*^9}, {
  3.8142821072469625`*^9, 3.8142821114027805`*^9}, {3.823896918829839*^9, 
  3.8238969218428216`*^9}},ExpressionUUID->"d335ec6b-135b-488b-99b9-\
543be3439e5f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pairwiseScatterPlot", "[", 
   RowBox[{
    RowBox[{"dataset_", "?", "MatrixQ"}], "/;", 
    RowBox[{"And", "@@", 
     RowBox[{"NumberQ", "/@", 
      RowBox[{"Flatten", "@", 
       RowBox[{"dataset", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"2", ";;"}], ",", 
          RowBox[{"2", ";;"}]}], "]"}], "]"}]}]}]}]}], " ", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "varnames", ",", "correlation", ",", "data", ",", "plotfunction"}], 
     "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "look", " ", "for", " ", "column", " ", "headers", " ", "or", " ", 
      "generate", " ", "generic", " ", "ones"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"this", " ", "assumes", " ", "that"}], ",", " ", 
      RowBox[{"if", " ", "there", " ", "are", " ", "column", " ", "headers"}],
       ",", " ", 
      RowBox[{
      "then", " ", "there", " ", "will", " ", "also", " ", "be", " ", "row", 
       " ", "headers", " ", "as", " ", "well"}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"Not", "@", 
        RowBox[{"NumberQ", "@", 
         RowBox[{"dataset", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"varnames", "=", 
         RowBox[{"dataset", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", 
            RowBox[{"2", ";;"}]}], "]"}], "]"}]}], ";", 
        RowBox[{"data", "=", 
         RowBox[{"dataset", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"2", ";;"}], ",", 
            RowBox[{"2", ";;"}]}], "]"}], "]"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"varnames", "=", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"\"\<var\>\"", "<>", 
             RowBox[{"ToString", "[", "#", "]"}]}], "&"}], ",", 
           RowBox[{"Last", "@", 
            RowBox[{"Dimensions", "[", "dataset", "]"}]}]}], "]"}]}], ";", 
        RowBox[{"data", "=", "dataset"}]}]}], "\[IndentingNewLine]", "]"}], 
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"calculate", " ", "the", " ", "correlation", " ", "matrix"}], 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{"correlation", "=", 
      RowBox[{"Correlation", "[", "data", "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"the", " ", "plotting", " ", "function"}], ",", " ", 
       RowBox[{
       "so", " ", "it", " ", "looks", " ", "cleaner", " ", "in", " ", "the", 
        " ", "grid"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"plotfunction", "[", 
       RowBox[{"i_", ",", "j_"}], "]"}], ":=", "\[IndentingNewLine]", 
      RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "j"}], "}"}]}], "]"}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
        RowBox[{"AspectRatio", "\[Rule]", "1"}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"FrameTicks", "\[Rule]", "None"}], ",", 
        RowBox[{"Axes", "\[Rule]", "False"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Prolog", "\[Rule]", 
         RowBox[{"Inset", "[", 
          RowBox[{"Style", "[", 
           RowBox[{
            RowBox[{"NumberForm", "[", 
             RowBox[{
              RowBox[{"correlation", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"1", ",", "2"}], "}"}]}], "]"}], ",", 
            RowBox[{"FontColor", "\[Rule]", 
             RowBox[{"GrayLevel", "[", ".7", "]"}]}], ",", 
            RowBox[{"FontSize", "\[Rule]", 
             RowBox[{"Scaled", "[", "0.35", "]"}]}]}], "]"}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Background", "\[Rule]", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"corr", "=", 
             RowBox[{"Abs", "@", 
              RowBox[{"correlation", "[", 
               RowBox[{"[", 
