          RowBox[{
          "the", " ", "first", " ", "column", " ", "contains", " ", "sample", 
           " ", "labels"}], ";", " ", 
          RowBox[{
          "use", " ", "them", " ", "to", " ", "sort", " ", "the", " ", 
