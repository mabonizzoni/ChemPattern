Cell[CellGroupData[{

Cell["effectOfRemovingVariables", "Section",
 CellChangeTimes->{{3.709036257159566*^9, 
  3.709036261388808*^9}},ExpressionUUID->"3786bec0-9f1d-4bf8-a05d-\
1b07b475388d"],

Cell[TextData[{
 "A helper function that attempts to show graphically the effect of removing \
more and more variables from a dataset on the LDA scores plot. Since the \
function doesn\[CloseCurlyQuote]t appear to be very useful, it is currently ",
 StyleBox["not exported",
  FontWeight->"Bold"],
 " from the package. It is also not protected."
}], "Text",
 CellChangeTimes->{{3.7090362665241013`*^9, 3.70903632332635*^9}, {
  3.7090363695369935`*^9, 3.709036376426388*^9}, {3.7633914697811346`*^9, 
  3.7633914699059353`*^9}},ExpressionUUID->"5859eca0-fb64-40af-aa1f-\
566def83691a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "effectOfRemovingVariables", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{"output", "->", "\"\<3D\>\""}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"effectOfRemovingVariables", "::", "syntax"}], "=", 
    "\"\<incorrect syntax / argument count, or unrealistic argument \
value\>\""}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"effectOfRemovingVariables", "[", 
     RowBox[{
      RowBox[{"dataset_", "?", "MatrixQ"}], ",", 
      RowBox[{"tmax_", ":", "15"}], ",", 
      RowBox[{"numsteps_", ":", "3"}], ",", 
      RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"0", "<", "tmax", "<", "100"}], "&&", 
      RowBox[{"numsteps", ">", "1"}]}], ")"}]}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"iterator", "=", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "tmax", ",", 
          RowBox[{"tmax", "/", 
           RowBox[{"(", 
            RowBox[{"numsteps", "-", "1"}], ")"}]}]}], "}"}]}], ",", 
       "assoclist", ",", "i"}], "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"assoclist", "=", 
       RowBox[{"iEffectOfRemovingVariables", "[", 
        RowBox[{"dataset", ",", "tmax", ",", "numsteps"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Switch", "[", 
       RowBox[{
        RowBox[{"OptionValue", "[", "output", "]"}], ",", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", "\"\<3D\>\"", ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"i", "=", "1"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Graphics3D", "[", 
          RowBox[{
           RowBox[{"{", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"KeyValueMap", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"ColorData", "[", "97", "]"}], "[", 
                   RowBox[{"i", "++"}], "]"}], ",", 
                  RowBox[{"Inset", "[", 
                   RowBox[{
                    RowBox[{"Style", "[", 
                    RowBox[{
                    RowBox[{"StringTake", "[", 
                    RowBox[{"#1", ",", "1"}], "]"}], ",", "Bold", ",", "14"}],
                     "]"}], ",", "#2"}], "]"}]}], "}"}], "&"}], ",", 
               "assoclist"}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Opacity", "[", "0.2", "]"}], ",", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"InfinitePlane", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"t", ",", "0", ",", "0"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"t", ",", "1", ",", "0"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"t", ",", "1", ",", "1"}], "}"}]}], "}"}], "]"}], 
                 ",", 
                 RowBox[{"Evaluate", "@", "iterator"}]}], "]"}]}], "}"}]}], 
            "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
           RowBox[{"PlotRangePadding", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"Scaled", "[", "0.05", "]"}], ",", 
              RowBox[{"Scaled", "[", "0.05", "]"}]}], "}"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"AxesLabel", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Style", "[", 
               RowBox[{
               "\"\<threshold\>\"", ",", "16", ",", "Black", ",", "Bold"}], 
               "]"}], ",", "\"\<F1\>\"", ",", "\"\<F2\>\""}], "}"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"BoxRatios", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"3", ",", " ", "1", ",", " ", "1"}], "}"}]}], ",", 
           RowBox[{"ImageSize", "\[Rule]", "Large"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Lighting", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"{", 
              RowBox[{"\"\<Ambient\>\"", ",", " ", "Gray"}], "}"}], "}"}]}], 
           ",", "\[IndentingNewLine]", 
           RowBox[{"Axes", "\[Rule]", "True"}], ",", 
           RowBox[{"AxesStyle", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Directive", "[", 
               RowBox[{"Black", ",", "Bold", ",", "16"}], "]"}], ",", 
              "Automatic", ",", "Automatic"}], "}"}]}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", "\"\<2D\>\"", ",", "\[IndentingNewLine]", 
        RowBox[{"Replace", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"KeyValueMap", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Framed", "@", 
              RowBox[{"ListPlot", "[", 
               RowBox[{"#2", ",", 
                RowBox[{"PlotLabel", "\[Rule]", 
                 RowBox[{"Style", "[", 
                  RowBox[{"#1", ",", "16", ",", "Red"}], "]"}]}], ",", 
                RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
                RowBox[{"Joined", "\[Rule]", "True"}], ",", 
                RowBox[{"Mesh", "\[Rule]", "Full"}], ",", 
                RowBox[{"Axes", "\[Rule]", "False"}], ",", 
                RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}]}], "&"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"assoclist", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "All", ",", 
               RowBox[{"2", ";;"}]}], "]"}], "]"}]}], "\[IndentingNewLine]", 
           "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Line", "[", "l_List", "]"}], "\[RuleDelayed]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Arrowheads", "\[Rule]", "Medium"}], ",", 
             RowBox[{"Arrow", "/@", 
              RowBox[{"Partition", "[", 
               RowBox[{"l", ",", "2", ",", "1"}], "]"}]}]}], "}"}]}], ",", 
          "\[IndentingNewLine]", "Infinity"}], "\[IndentingNewLine]", "]"}], 
        ",", "\[IndentingNewLine]", "\[IndentingNewLine]", "_", ",", 
        RowBox[{
         RowBox[{"Message", "[", 
          RowBox[{"effectOfRemovingVariables", "::", "syntax"}], "]"}], ";", 
         RowBox[{"Message", "[", 
          RowBox[{"effectOfRemovingVariables", "::", "usage"}], "]"}]}]}], 
       "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"effectOfRemovingVariables", "[", "___", "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Message", "[", 
      RowBox[{"effectOfRemovingVariables", "::", "syntax"}], "]"}], ";", 
     RowBox[{"Message", "[", 
      RowBox[{"effectOfRemovingVariables", "::", "usage"}], "]"}]}], ")"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", "iEffectOfRemovingVariables", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iEffectOfRemovingVariables", "[", 
   RowBox[{"dataset_", ",", "tmax_", ",", "numsteps_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"iterator", "=", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "tmax", ",", 
        RowBox[{"tmax", "/", 
         RowBox[{"(", 
          RowBox[{"numsteps", "-", "1"}], ")"}]}]}], "}"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Merge", "[", "Identity", "]"}], "@", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Map", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "t", "}"}], ",", "#"}], "]"}], "&"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Mean", "/@", 
          RowBox[{
           RowBox[{"GroupBy", "[", 
            RowBox[{"First", "\[Rule]", "Rest"}], "]"}], "@", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"lda", "[", 
             RowBox[{
              RowBox[{"filterVars", "[", 
               RowBox[{"dataset", ",", "t", ",", 
                RowBox[{"output", "\[Rule]", "\"\<ReducedSet\>\""}]}], "]"}], 
              ",", 
              RowBox[{"output", "\[Rule]", "\"\<scores\>\""}]}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"2", ";;"}], ",", 
              RowBox[{"1", ";;", "3"}]}], "]"}], "]"}]}]}]}], 
        "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Evaluate", "@", "iterator"}]}], "\[IndentingNewLine]", 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.7090363415303917`*^9, {3.709036696324685*^9, 3.7090367002909117`*^9}, {
   3.7633928178823214`*^9, 3.7633928396629596`*^9}},
 CellLabel->
  "In[1023]:=",ExpressionUUID->"751d0f00-22d5-4d81-9fa7-6a24795c670a"]
}, Closed]],

Cell[CellGroupData[{

Cell["removeOutliers: helper function to remove outlier points", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.706566519778354*^9, 3.706566574743251*^9}, {
  3.706566644510574*^9, 
  3.7065666669600134`*^9}},ExpressionUUID->"d44ca89c-3627-4560-9399-\
af2a3a195704"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"removeOutliers", "::", "dups"}], "=", 
   "\"\<Duplicate sample names found in list of points to remove\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"removeOutliers", "::", "missing"}], "=", 
    "\"\<One of the specified sample names does not exist in the full \
dataset: check spelling?\>\""}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"removeOutliers", "[", 
    RowBox[{"dataset_", "?", "MatrixQ"}], "]"}], "[", 
   RowBox[{"argseq", ":", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"_String", ",", "_List"}], "}"}], ".."}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "allSamplesInSet", ",", "listToRemove", ",", "datasetAsAssociation", ",",
       "removalRules"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"listToRemove", "=", 
      RowBox[{"List", "@", "argseq"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"allSamplesInSet", "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"dataset", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"2", ";;"}], ",", "1"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Check", " ", "for", " ", "duplicate", " ", "sample", " ", "names", " ",
        "in", " ", "argseq"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Not", "@*", "DuplicateFreeQ"}], "@", 
        RowBox[{"listToRemove", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{"removeOutliers", "::", "dups"}], "]"}], ";", 
        RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"Check", " ", "for", " ", "mis"}], "-", 
       RowBox[{"spelled", " ", "or", " ", "otherwise", " ", "non"}], "-", 
       RowBox[{
       "matching", " ", "sample", " ", "names", " ", "in", " ", "argseq"}]}], 
      " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"allSamplesInSet", "~", 
        RowBox[{"(", 
         RowBox[{"Not", "@*", "ContainsAll"}], ")"}], "~", 
        RowBox[{"listToRemove", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{"removeOutliers", "::", "missing"}], "]"}], ";", 
        RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"datasetAsAssociation", "=", 
      RowBox[{"GroupBy", "[", 
       RowBox[{"dataset", ",", "First"}], "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"removalRules", "=", 
      RowBox[{"Join", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"AssociationThread", "[", 
         RowBox[{"allSamplesInSet", "\[Rule]", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{
            RowBox[{"{", "}"}], ",", 
            RowBox[{"Length", "@", "allSamplesInSet"}]}], "]"}]}], "]"}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{"Rule", "@@", 
          RowBox[{"Transpose", "@", "listToRemove"}]}], "]"}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Join", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"dataset", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"#", ",", "1"}], "]"}], "&"}], "@", "\[IndentingNewLine]", 
        RowBox[{"KeyValueMap", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"datasetAsAssociation", "[", "#1", "]"}], "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Range", "[", 
               RowBox[{"Length", "[", 
                RowBox[{"datasetAsAssociation", "[", "#1", "]"}], "]"}], 
               "]"}], "~", "Complement", "~", "#2"}], "]"}], "]"}], "&"}], 
          ",", "removalRules"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7065666863352475`*^9, 3.706566686928048*^9}, {
  3.70657469488535*^9, 3.7065748127747574`*^9}, {3.7074774031168833`*^9, 
  3.7074774042868853`*^9}},
 CellLabel->
  "In[1029]:=",ExpressionUUID->"fcf25d58-4919-440c-8dcd-732aa8c93d3d"]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
overview: generates sparklines for each instrumental variable in the dataset, \
for quick identification of useless variables\
\>", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.707148170914011*^9, 3.7071482084320765`*^9}, 
   3.75242264639922*^9},ExpressionUUID->"19e13c3c-3d64-4f36-82d6-\
d19fc3cf2a59"],

Cell[CellGroupData[{

Cell["Added an alternative tabular output (March 2022)", "Subsection",
 CellChangeTimes->{{3.7633916371832314`*^9, 3.7633916423312407`*^9}, {
  3.763391707736556*^9, 3.7633917220019813`*^9}, {3.7633920746390038`*^9, 
  3.7633920785546107`*^9}, {3.793722007818711*^9, 3.7937220250772614`*^9}, {
  3.8413088341794305`*^9, 3.841308847839653*^9}, {3.8413104044986134`*^9, 
  3.841310423715234*^9}, {3.8553349305183206`*^9, 
  3.8553349422630157`*^9}},ExpressionUUID->"c6498c50-e2c0-404a-9fe4-\
1f317f0ca786"],

Cell["\<\
Reports on aggregate or group-wise statistics of each raw measurement to \
identify potentially bad values (overflow, too low, too high, too noisy) from \
the values themselves, which are otherwise not reported in the sparklines.
Changed the implementation approach to having two internal implementation \
functions selected by an \
\[OpenCurlyDoubleQuote]output\[CloseCurlyDoubleQuote] option. The function \
defaults to generation of sparklines when no option is given for backwards \
compatibility.\
\>", "Text",
 CellChangeTimes->{{3.7633917866222954`*^9, 3.763391790866503*^9}, {
  3.7937220298462334`*^9, 3.79372206735904*^9}, {3.793728087999032*^9, 
  3.7937280927929883`*^9}, {3.793728279361116*^9, 3.793728307923614*^9}, {
  3.8413104265256305`*^9, 3.841310515575274*^9}, {3.8553349572251434`*^9, 
  3.8553350121578526`*^9}, {3.8553373116806803`*^9, 
  3.8553373649274282`*^9}},ExpressionUUID->"a25f1d79-db95-4b51-bd49-\
9f1e4b8f1bc5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Added a preliminary sorting of the dataset (September 2021)", \
"Subsection",
 CellChangeTimes->{{3.7633916371832314`*^9, 3.7633916423312407`*^9}, {
  3.763391707736556*^9, 3.7633917220019813`*^9}, {3.7633920746390038`*^9, 
  3.7633920785546107`*^9}, {3.793722007818711*^9, 3.7937220250772614`*^9}, {
  3.8413088341794305`*^9, 3.841308847839653*^9}, {3.8413104044986134`*^9, 
  3.841310423715234*^9}},ExpressionUUID->"fcc29622-cfae-4272-a113-\
ad0dae0de6ea"],

Cell["\<\
If replicates for the same sample are not contiguous in the raw data table, \
overview reported jumbled results. If row labels are present, the function \
first sorts the dataset by each row\[CloseCurlyQuote]s first entry (i.e. the \
label) before constructing the plots.\
\>", "Text",
 CellChangeTimes->{{3.7633917866222954`*^9, 3.763391790866503*^9}, {
  3.7937220298462334`*^9, 3.79372206735904*^9}, {3.793728087999032*^9, 
  3.7937280927929883`*^9}, {3.793728279361116*^9, 3.793728307923614*^9}, {
  3.8413104265256305`*^9, 
  3.841310515575274*^9}},ExpressionUUID->"64c74078-ec6b-4527-bea0-\
c632abe062b4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Barchart functionality (added in March 2020, commented out and removed in \
September 2021; code removed in March 2022)\
\>", "Subsection",
 CellChangeTimes->{{3.7633916371832314`*^9, 3.7633916423312407`*^9}, {
  3.763391707736556*^9, 3.7633917220019813`*^9}, {3.7633920746390038`*^9, 
  3.7633920785546107`*^9}, {3.793722007818711*^9, 3.7937220250772614`*^9}, {
  3.8413088341794305`*^9, 3.841308847839653*^9}, {3.8553372834008536`*^9, 
  3.8553372968539534`*^9}},ExpressionUUID->"3710e81c-5bff-40e1-a3b6-\
d3bb1759191e"],

Cell["\<\
The existing overview showed a sparkline for each instrumental measurement in \
the dataset. 
The added functionality generates a bar chart approximating the relative \
information content of each instrumental measurements.\
\>", "Text",
 CellChangeTimes->{{3.7633917866222954`*^9, 3.763391790866503*^9}, {
  3.7937220298462334`*^9, 3.79372206735904*^9}, {3.793728087999032*^9, 
  3.7937280927929883`*^9}, {3.793728279361116*^9, 
  3.793728307923614*^9}},ExpressionUUID->"f14fbae6-d8f8-497c-b048-\
92bd2c11d96b"],

Cell[TextData[{
 "Using non-standardized data, a \[OpenCurlyDoubleQuote]",
 StyleBox["standard deviation of replication",
  FontWeight->"Bold"],
 "\[CloseCurlyDoubleQuote] is determined for each instrumental variable, by \
calculating the standard deviation among replicates  of the same sample for \
that variable. We then take the ",
 StyleBox["maximum",
  FontSlant->"Italic"],
 " among those values as the most representative. Then we calculate the \
standard deviation of all measurements for a certain variable (",
 StyleBox["total standard deviation",
  FontWeight->"Bold"],
 ")."
}], "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.7633918084507337`*^9}, 
   3.763392449285468*^9, {3.7937283213519545`*^9, 3.7937283992350626`*^9}, {
   3.7937284846372166`*^9, 3.7937285314257545`*^9}, {3.7937287235879135`*^9, 
   3.7937287348550234`*^9}, {3.793728883273199*^9, 
   3.793728883610722*^9}},ExpressionUUID->"c9ed1e79-11c6-4865-a947-\
e4f2e6bc480e"],

Cell[TextData[{
 "The ",
 StyleBox["ratio between these two",
  FontWeight->"Bold"],
 " indicates how much ",
 StyleBox["variability among samples there is in each measurement channel",
  FontWeight->"Bold"],
 " that is not induced by noise. For instance, if a measurement is constant \
through the data set (so it conveys no information) but it is naturally \
affected by large errors, it may show up as having \
\[OpenCurlyDoubleQuote]high variance\[CloseCurlyDoubleQuote], although that \
variance is mostly due to noise. "
}], "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.7633918084507337`*^9}, 
   3.763392449285468*^9, {3.7937283213519545`*^9, 3.7937283992350626`*^9}, {
   3.7937284846372166`*^9, 3.7937284846372166`*^9}, {3.793728775608698*^9, 
   3.7937287922888384`*^9}, {3.793728864214362*^9, 
   3.793729067737501*^9}},ExpressionUUID->"2f3dde51-d41c-45c0-81f5-\
66ff52372234"],

Cell[CellGroupData[{

Cell["\<\
All variables may be shown, but by default a threshold of 3 is used, i.e. \
only those variables are plotted that show intersample deviations that are \
larger than 3x the max intrasample deviation, with the assumptions that those \
with lower values are less important. \
\>", "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.7633918084507337`*^9}, 
   3.763392449285468*^9, {3.7937283213519545`*^9, 3.7937283992350626`*^9}, {
   3.7937284846372166`*^9, 3.7937284846372166`*^9}, {3.793728775608698*^9, 
   3.7937287922888384`*^9}, {3.793728864214362*^9, 
   3.793729134133226*^9}},ExpressionUUID->"1d9d9f23-5590-480b-bb46-\
06fd62b2c555"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "overview", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{"output", "->", "\"\<Sparklines\>\""}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"overview", "::", "wrongoption"}], "=", 
    "\"\<The option `1` is not recognized. Valid output options are \
\\\"Sparklines\\\" (the default) and \\\"Table\\\".\>\""}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"overview", "[", 
    RowBox[{
     RowBox[{"data_", "?", "MatrixQ"}], ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Switch", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"OptionValue", "[", "output", "]"}], ",", "\[IndentingNewLine]", 
     "\"\<Table\>\"", ",", 
     RowBox[{"iOverviewTable", "[", "data", "]"}], ",", 
     "\[IndentingNewLine]", "\"\<Sparklines\>\"", ",", 
     RowBox[{"iOverviewSparklines", "[", "data", "]"}], ",", 
     "\[IndentingNewLine]", "_", ",", 
     RowBox[{"Message", "[", 
      RowBox[{
       RowBox[{"overview", "::", "wrongoption"}], ",", 
       RowBox[{"OptionValue", "[", "output", "]"}]}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", "iOverviewTable", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"iOverviewTable", "[", "data_", "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "measurementNames", ",", "aggregateDescriptors", ",", 
       "groupedDataDescriptors", ",", "combinedDescriptors", ",", 
       "formattedDescriptors"}], "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
        "Take", " ", "names", " ", "of", " ", "measurements", " ", "from", 
         " ", "first", " ", "row"}], ";", " ", 
        RowBox[{
        "remove", " ", "the", " ", "blank", " ", "space", " ", "in", " ", 
         "position", " ", "1"}]}], ",", "1"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"measurementNames", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", 
          RowBox[{"2", ";;"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "simple", " ", "descriptive", " ", "statistics", " ", "on", " ", 
         "the", " ", "entire", " ", "dataset"}], ",", " ", 
        RowBox[{"measurement", "-", "wise"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"aggregateDescriptors", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Min", "[", "#", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Max", "[", "#", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Median", "[", "#", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Mean", "[", "#", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"StandardDeviation", "[", "#", "]"}]}], 
          "\[IndentingNewLine]", "}"}], "&"}], "/@", 
        RowBox[{
         RowBox[{"Transpose", "[", "data", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"2", ";;"}], ",", 
           RowBox[{"2", ";;"}]}], "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"medians", " ", "by", " ", "analyte"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"groupedDataDescriptors", "=", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"##", ",", 
           RowBox[{"#2", "-", "#1"}]}], "}"}], "&"}], "@@@", 
        "\[IndentingNewLine]", 
        RowBox[{"MinMax", "/@", "\[IndentingNewLine]", 
         RowBox[{"Transpose", "@", "\[IndentingNewLine]", 
          RowBox[{"Values", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Map", "[", 
              RowBox[{"Median", ",", "#", ",", 
               RowBox[{"{", "2", "}"}]}], "]"}], "&"}], "@", 
            "\[IndentingNewLine]", 
            RowBox[{"GroupBy", "[", 
             RowBox[{
              RowBox[{"data", "[", 
               RowBox[{"[", 
                RowBox[{"2", ";;"}], "]"}], "]"}], ",", 
              RowBox[{"First", "->", "Rest"}], ",", "Transpose"}], "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}]}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "combine", " ", "simple", " ", "and", " ", "grouped", " ", 
        "descriptors", " ", "for", " ", "each", " ", "measurement", " ", "in",
         " ", "one", " ", "row"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"combinedDescriptors", "=", 
       RowBox[{"Flatten", "/@", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"aggregateDescriptors", ",", "groupedDataDescriptors"}], 
          "}"}], "]"}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "format", " ", "descriptors", " ", "to", " ", "align", " ", "them", 
        " ", "on", " ", "decimal", " ", "point", " ", "when", " ", "in", " ", 
        "tabular", " ", "form"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"formattedDescriptors", "=", "\[IndentingNewLine]", 
       RowBox[{"Map", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"PaddedForm", "[", 
           RowBox[{"#", ",", 
            RowBox[{"{", 
             RowBox[{"6", ",", "3"}], "}"}], ",", 
            RowBox[{"NumberPadding", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"\"\< \>\"", ",", "\"\< \>\""}], "}"}]}], ",", 
            RowBox[{"DigitBlock", "->", "3"}], ",", 
            RowBox[{"NumberSeparator", "->", "\"\<\[ThinSpace]\>\""}]}], 
           "\[ThinSpace]", "]"}], "&"}], ",", "\[IndentingNewLine]", 
         "combinedDescriptors", ",", "\[IndentingNewLine]", 
         RowBox[{"{", "2", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Generate", " ", "output"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"TableForm", "[", "\[IndentingNewLine]", 
       RowBox[{"formattedDescriptors", ",", "\[IndentingNewLine]", 
        RowBox[{"TableHeadings", "\[Rule]", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{"measurementNames", ",", "\[IndentingNewLine]", 
           RowBox[{"{", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Tooltip", "[", 
              RowBox[{
              "\"\<min\>\"", ",", 
               "\"\<MINIMUM raw reading for this\\nmeasurement across all \
samples\>\""}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{"Tooltip", "[", 
              RowBox[{
              "\"\<max\>\"", ",", 
               "\"\<MAXIMUM raw reading for this\\nmeasurement across all \
samples\>\""}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{"Tooltip", "[", 
              RowBox[{
              "\"\<median\>\"", ",", 
               "\"\<MEDIAN reading for this\\nmeasurement across all \
samples\>\""}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{"Tooltip", "[", 
              RowBox[{
              "\"\<ave\>\"", ",", 
               "\"\<AVERAGE reading for this\\nmeasurement across all samples\
\>\""}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{"Tooltip", "[", 
              RowBox[{
              "\"\<stdev\>\"", ",", 
               "\"\<Standard deviation for this measurement across all \
samples\>\""}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{"Tooltip", "[", 
              RowBox[{
              "\"\<minMedian\>\"", ",", 
               "\"\<smallest of the medians of\\ngrouped replicates of each \
sample\>\""}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{"Tooltip", "[", 
              RowBox[{
              "\"\<maxMedian\>\"", ",", 
               "\"\<largest of the medians of\\ngrouped replicates of each \
sample\>\""}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{"Tooltip", "[", 
              RowBox[{
              "\"\<maxDeltaMedian\>\"", ",", 
               "\"\<difference between the medians of the replicate \
set\\nwith the highest vs. the lowest median value\\nfor each \
measurement\>\""}], "]"}]}], "\[IndentingNewLine]", "}"}]}], 
          "\[IndentingNewLine]", "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"TableAlignments", "->", 
         RowBox[{"{", 
          RowBox[{"Right", ",", "Center"}], "}"}]}]}], "\[IndentingNewLine]", 
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", "iOverviewSparklines", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iOverviewSparklines", "[", "data_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"workingdata", ",", "sparklines"}], "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "Check", " ", "for", " ", "the", " ", "presence", " ", "of", " ", 
       "sample", " ", "labels"}], ",", " ", 
      RowBox[{
      "and", " ", "remove", " ", "them", " ", "if", " ", "present"}]}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Also", " ", "stable"}], "-", 
      RowBox[{
      "sort", " ", "the", " ", "dataset", " ", "so", " ", "replicates", " ", 
       "for", " ", "the", " ", "same", " ", "sample", " ", "are", " ", 
       "guaranteed", " ", "to", " ", "be", " ", "contiguous"}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"note", "!"}], " ", "this", " ", "works", " ", "on", " ", "the",
       " ", "assumption", " ", "that", " ", 
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}], " ", "is", " ", "an", " ", 
      "EMPTY", " ", 
      RowBox[{"STRING", ":", " ", 
       RowBox[{
       "otherwise", " ", "the", " ", "measurement", " ", "names", " ", "get", 
        " ", "alphabetized", " ", "out", " ", "of", " ", "order"}]}]}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"workingdata", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"StringQ", "@", 
         RowBox[{"data", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
