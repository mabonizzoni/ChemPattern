Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["pca", "Code",
  FontWeight->"Plain"],
 ": a PCA helper function"
}], "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.672432723397172*^9, 3.6724327295791807`*^9}, {
  3.673379032072715*^9, 3.673379038469081*^9}, {3.8238970767780232`*^9, 
  3.823897076902956*^9}},ExpressionUUID->"c69f7bd4-9283-44c0-bfef-\
3c3b93ef67c3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "pca", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"output", "\[Rule]", "\"\<2DL\>\""}], ",", 
      RowBox[{"confidencelevel", "->", "0.95"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pca", "::", "outputoptions"}], "=", 
   "\"\<The value `1` is not a valid plotting option. Valid options are: \
\\\"2DL\\\" (default), \\\"2D\\\", \\\"scores\\\", \\\"eigenvectors\\\", \
\\\"eigensystem\\\", \\\"vartable\\\", \\\"varlist\\\".\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"pca", "::", "conflevel"}], "=", 
    "\"\<`1` is an invalid value for the confidence level (0 < p < 1). The \
default 95% confidence level will be used instead.\>\""}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pca", "[", 
   RowBox[{
    RowBox[{"data_", "?", "MatrixQ"}], ",", 
    RowBox[{"options", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"vars", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", 
          RowBox[{"2", ";;"}]}], "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"labels", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"2", ";;"}], ",", "1"}], "]"}], "]"}]}], ",", 
      "\[IndentingNewLine]", "confidenceLevel", ",", "\[IndentingNewLine]", 
      "scores", ",", "scores2D", ",", "annotated", ",", "scoregroups", ",", 
      "\[IndentingNewLine]", "leftSingularValues", ",", "s", ",", 
      "eigenvecsT", ",", "\[IndentingNewLine]", "eigenvals", ",", 
      "eigenvecs"}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]",
     "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "Set", " ", "the", " ", "confidence", " ", "level", " ", "for", " ", 
      "ellipsoid", " ", "plotting"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "The", " ", "deafult", " ", "value", " ", "is", " ", "0.95", " ", "for", 
      " ", "95", "%", " ", "confidence"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "Incorrect", " ", "values", " ", "trigger", " ", "a", " ", "message"}], 
      ",", 
      RowBox[{
      "but", " ", "the", " ", "calculation", " ", "continues", " ", 
       "anyway"}], ",", 
      RowBox[{
      "using", " ", "the", " ", "default", " ", "95", "%", " ", "confidence", 
       " ", "level"}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"confidenceLevel", "=", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"cf", "=", 
          RowBox[{"OptionValue", "[", "\"\<confidencelevel\>\"", "]"}]}], 
         "}"}], ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"NumericQ", "[", "cf", "]"}], "&&", 
           RowBox[{"0", "<", "cf", "<", "1"}]}], ",", "cf", ",", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"pca", "::", "conflevel"}], ",", "cf"}], "]"}], ";", 
           "0.95"}]}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"results", " ", "of", " ", "singular", " ", "value", " ", 
       RowBox[{"decomposition", ":", " ", 
        RowBox[{"{", 
         RowBox[{"leftSingularValues", ",", " ", "s", ",", " ", 
          RowBox[{"Transpose", "@", "rightSingularValues"}]}], "}"}]}]}], " ",
       "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"PCA", " ", "scores"}], " ", "=", " ", 
       RowBox[{"leftSingularValues", ".", "s"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "eigenVALUES", " ", "of", " ", "the", " ", "correlation", " ", "of", 
        " ", "data"}], " ", "=", " ", 
       RowBox[{"diagonal", " ", "elements", " ", "of", " ", 
        RowBox[{
         RowBox[{"s", "^", "2"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"number", " ", "of", " ", "variables"}], " ", "-", " ", 
           "1"}], ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "note", " ", "that", " ", "in", " ", "most", " ", "cases", " ", "the", 
        " ", "normalization", " ", "factor", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"number", " ", "of", " ", "variables"}], " ", "-", " ", 
          "1"}], ")"}], " ", "can", " ", "be", " ", "ignored"}], ",", " ", 
       RowBox[{
       "because", " ", "the", " ", "eigenvalues", " ", "will", " ", "be", " ",
         "renormalized", " ", "anyway"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "the", " ", "right", " ", "singular", " ", "values", " ", "happen", " ",
        "to", " ", "be", " ", "the", " ", "eigenVECTORS", " ", "of", " ", 
       "the", " ", "correlation", " ", "matrix", " ", "of", " ", "data"}], 
      " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "here", " ", "they", " ", "are", " ", "indicated", " ", "as", " ", 
        "eigenvecsT"}], ",", " ", 
       RowBox[{
        RowBox[{
        "because", " ", "they", " ", "are", " ", "returned", " ", "column"}], 
        "-", 
        RowBox[{"wise", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"i", ".", "e", ".", " ", "each"}], " ", "column", " ", 
           "of", " ", "evecsT", " ", "is", " ", "an", " ", "eigenvector"}], 
          ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"think", " ", "of", " ", "it", " ", 
          RowBox[{"as", ":", " ", "eigenvecsT"}]}], " ", "=", " ", 
         RowBox[{"Transpose", "@", 
          RowBox[{"Eigenvectors", "[", 
           RowBox[{"Correlation", "@", "data"}], "]"}]}]}], ";", " ", 
        RowBox[{"ignoring", " ", "sign", " ", "changes"}]}], ",", " ", 
       RowBox[{
       "since", " ", "sign", " ", "is", " ", "arbitrary", " ", "anyway"}]}], 
      " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"leftSingularValues", ",", "s", ",", "eigenvecsT"}], "}"}], 
      "=", 
      RowBox[{"SingularValueDecomposition", "[", 
       RowBox[{"Standardize", "@", 
        RowBox[{"data", "\[LeftDoubleBracket]", 
         RowBox[{
          RowBox[{"2", ";;"}], ",", 
          RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"eigenvals", "=", 
      RowBox[{
       RowBox[{"Diagonal", "[", "s", "]"}], "^", "2"}]}], ";", 
     "\[IndentingNewLine]", 
