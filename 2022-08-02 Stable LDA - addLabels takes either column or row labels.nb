Cell[CellGroupData[{

Cell["groupcontribs: group contribution helper functions", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.6449389816861835`*^9, 3.644938989220997*^9}, {
  3.8656799765164948`*^9, 
  3.865679980015252*^9}},ExpressionUUID->"859c083f-e271-477d-8ebe-\
faf0115d03f1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "following", " ", "function", " ", "generates", " ", "a", " ", 
    "bar", " ", "chart", " ", "of", " ", "the", " ", "weighted", " ", 
    "contributions", " ", "of", " ", "each", " ", "sensor", " ", "to", " ", 
    "the", " ", "overall", " ", "discrimination"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "The", " ", "contributions", " ", "are", " ", "weighted", " ", "by", " ", 
     "the", " ", "weight", " ", "of", " ", "the", " ", "factors", " ", 
     "themselves"}], ",", " ", 
    RowBox[{
    "represented", " ", "by", " ", "the", " ", "eigenvalues", " ", "from", 
     " ", "lda"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "because", " ", "a", " ", "sensor", " ", "that", 
    " ", "contributes", " ", "a", " ", "lot", " ", "to", " ", "an", " ", 
    "unimportant", " ", "factor", " ", "is", " ", "still", " ", "unimportant",
     " ", "in", " ", "the", " ", "overall", " ", "discrimination"}], " ", 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"groupcontribs", "::", "numgroups"}], "=", 
     "\"\<The number of variables in the eigensystem (`1`) is not an exact \
multiple of the number of groups provided (`2`).\>\""}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"groupcontribs", "[", 
     RowBox[{"eigensystem_", ",", "numberofgroups_", ",", 
      RowBox[{"sensornames_", ":", "Null"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"eigenvals", "=", 
         RowBox[{
         "eigensystem", "\[LeftDoubleBracket]", "1", 
          "\[RightDoubleBracket]"}]}], ",", 
        RowBox[{"eigenvecs", "=", 
         RowBox[{
         "eigensystem", "\[LeftDoubleBracket]", "2", 
          "\[RightDoubleBracket]"}]}], ",", "variablespergroup", ",", 
        "sqweightedeigenvecs", ",", "barvalues"}], "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"Length", "@", "eigenvecs"}], ",", "numberofgroups"}], 
           "]"}], "\[Equal]", "0"}], ",", "\[IndentingNewLine]", 
         RowBox[{"variablespergroup", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Length", "@", "eigenvecs"}], ")"}], "/", 
           "numberofgroups"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Message", "[", 
           RowBox[{
            RowBox[{"groupcontribs", "::", "numgroups"}], ",", 
            RowBox[{"Length", "@", "eigenvecs"}], ",", "numberofgroups"}], 
           "]"}], ";", 
          RowBox[{"Abort", "[", "]"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "eigenvectors", " ", "are", " ", "weighted", " ", "by", " ", "the", 
          " ", "corresponding", " ", "eigenvalues"}], ",", " ", 
         RowBox[{"then", " ", "squared"}]}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"sqweightedeigenvecs", "=", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Normalize", "[", 
            RowBox[{"eigenvals", ",", "Total"}], "]"}], "eigenvecs"}], ")"}], 
         "2"]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"barvalues", "=", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{
              RowBox[{"100", "#"}], ",", "1"}], "]"}], "&"}], "@", 
           "\[IndentingNewLine]", 
           RowBox[{"Normalize", "[", 
            RowBox[{"#", ",", "Total"}], "]"}]}], "&"}], "@", 
         "\[IndentingNewLine]", 
         RowBox[{"Table", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Chop", "@", 
            RowBox[{"Total", "[", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"sqweightedeigenvecs", "\[LeftDoubleBracket]", 
                RowBox[{"All", ",", 
                 RowBox[{"i", ";;", 
                  RowBox[{"variablespergroup", "-", "1", "+", "i"}]}]}], 
                "\[RightDoubleBracket]"}], "2"], ",", "Infinity"}], "]"}]}], 
           ",", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{
              RowBox[{"Last", "@", 
               RowBox[{"Dimensions", "@", "eigenvecs"}]}], "-", 
              "variablespergroup", "+", "1"}], ",", "variablespergroup"}], 
            "}"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"BarChart", "[", "\[IndentingNewLine]", 
        RowBox[{"barvalues", ",", "\[IndentingNewLine]", 
         RowBox[{"ChartLabels", "\[Rule]", 
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"#", ",", 
               RowBox[{"FontSize", "\[Rule]", "20"}], ",", "Black"}], "]"}], 
             "&"}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"sensornames", "===", "Null"}], ",", 
              RowBox[{"Array", "[", 
               RowBox[{"group", ",", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"Last", "@", 
                   RowBox[{"Dimensions", "@", "eigenvecs"}]}], ")"}], "/", 
                 "variablespergroup"}]}], "]"}], ",", "sensornames"}], 
             "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"BarSpacing", "\[Rule]", "Large"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"PlotLabel", "\[Rule]", 
          RowBox[{"Style", "[", 
           RowBox[{
           "\"\<% contribution of each sensor (overall)\>\"", ",", "Black", 
            ",", 
            RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
            RowBox[{"FontSize", "\[Rule]", "20"}]}], "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"ImageSize", "\[Rule]", 
          RowBox[{"Scaled", "[", "0.25", "]"}]}]}], "\[IndentingNewLine]", 
        "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6546161175175524`*^9, 3.654616118219554*^9}, {
   3.654616432130107*^9, 3.6546164344545107`*^9}, {3.6745874433008575`*^9, 
   3.674587443724882*^9}, 3.674587502941269*^9, 3.707477188222506*^9},
 CellLabel->
  "In[980]:=",ExpressionUUID->"3554c7b1-f728-470a-ace0-f82c8012ab88"]
}, Closed]],

Cell[CellGroupData[{

Cell["outlierPCA: detection of outliers using PCA", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.643117232420475*^9, 3.6431172448324924`*^9}, {
  3.865679983988651*^9, 
  3.865679986179013*^9}},ExpressionUUID->"5ac5292e-7bf3-4a73-b8cf-\
f9dcc3e1aa80"],

Cell[CellGroupData[{

Cell["\<\
The \[OpenCurlyDoubleQuote]manual\[CloseCurlyDoubleQuote] version: shows \
all-data ellipsoid, lets user choose outliers\
\>", "Subsection",
 CellChangeTimes->{{3.707743610737771*^9, 
  3.707743644740716*^9}},ExpressionUUID->"15392573-ff95-420d-b3dc-\
bae66324fba0"],

Cell[TextData[{
 "The old outlierPCA used calculated the principal components using the \
eigensystem of the correlation of the data. \nThis was always VERY fragile, \
and had recently become the least dependable link in the toolchain.\nThis \
function has been rewritten (2017-06-26) to use the built-in ",
 StyleBox["PrincipalComponents[]", "Input"],
 ". The built-in is much more robust, probably because it implements SVD or \
similar.\n\nThe manual version was finally superseded by the automatic one \
below in Dec 2018.\nThe main difference is in the fact that the automatic \
version plot an ellipsoid of confidence recalculated AFTER outlier removal, \
rather than plotting the ellipsoid corresponding to all data in a subset."
}], "Text",
 CellChangeTimes->{{3.707511441413858*^9, 3.7075116211631393`*^9}, {
  3.7528513321645412`*^9, 
  3.752851401014683*^9}},ExpressionUUID->"38046eb0-c98e-4c01-a9ad-\
3d82896ec444"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The first automated version became standard in Dec 2018; it used to be called \
outlierPCAauto\
\>", "Subsection",
 CellChangeTimes->{{3.707743651821121*^9, 3.707743681127797*^9}, {
  3.7077621897290854`*^9, 3.7077621967646976`*^9}, {3.752851408721898*^9, 
  3.75285142962934*^9}, {3.763391664236679*^9, 
  3.7633916732544947`*^9}},ExpressionUUID->"39b5e167-8c2a-4eae-bf42-\
4a7f2ab7914f"],

Cell["\<\
This version used the same machinery as the manual one, but it showed points \
outside of the original ellipsoid in red, then plotted data together with the \
ellipsoid that would be obtained if the alleged outliers were removed from \
the set.\
\>", "Text",
 CellChangeTimes->{{3.707743685422043*^9, 3.7077437336127996`*^9}, {
  3.7633916774821024`*^9, 
  3.763391689230923*^9}},ExpressionUUID->"f47fea75-ec81-4851-9de0-\
3ff76ed45016"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The newer recursive version, rewritten from scratch in Dec 2018\
\>", "Subsection",
 CellChangeTimes->{{3.7633916371832314`*^9, 3.7633916423312407`*^9}, {
  3.763391707736556*^9, 3.7633917220019813`*^9}, {3.7633920746390038`*^9, 
  3.7633920785546107`*^9}},ExpressionUUID->"864f14e9-b55e-4d4e-bd36-\
c415acfab880"],

Cell["Included upgrades:", "Text",
 CellChangeTimes->{{3.7633917866222954`*^9, 
  3.763391790866503*^9}},ExpressionUUID->"3c86529a-e2b8-4c80-9b45-\
8c426e8c28d2"],

Cell[TextData[{
 "The ",
 StyleBox["aspect ratio of the plots",
  FontWeight->"Bold"],
 " was changed to automatic, so round ellipsoids would show up as round: the \
shape of the ellipsoid would therefore have ",
 StyleBox["meaning",
  FontSlant->"Italic"]
}], "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.7633918084507337`*^9}, 
   3.763392449285468*^9},ExpressionUUID->"ac1e64cc-d958-41f0-8c77-\
fd231b786a13"],

Cell[TextData[{
 StyleBox["Recursion",
  FontWeight->"Bold"],
 " was implemented; outlierPCA now applies itself recursively to its own \
output, discarding points identified as outliers at each round, until there \
is no further change."
}], "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.763391886293271*^9}, {
  3.763392450565671*^9, 
  3.763392451768873*^9}},ExpressionUUID->"3d7d6df1-a862-47b9-a467-\
a85813d4fd36"],

Cell[TextData[{
 "The width of the ellipsoid that captures 95% of the points in ",
 StyleBox["n",
  FontSlant->"Italic"],
 " dimensions is approximated by\[LineSeparator]1.892 + 2.133 ",
 StyleBox["n",
  FontSlant->"Italic"],
 " - 0.06906 ",
 StyleBox["n",
  FontSlant->"Italic"],
 "^2 + 0.001985 ",
 StyleBox["n",
  FontSlant->"Italic"],
 "^3\[LineSeparator]This was arrived at separately (see the \
\[OpenCurlyDoubleQuote]making of recursive outlierPCA\[CloseCurlyDoubleQuote] \
notebook); it should still be replaced with an explicit reference to an \
appropriate chi-squared distribution."
}], "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.763391874882651*^9}, {
  3.763391922455335*^9, 
  3.763391999813272*^9}},ExpressionUUID->"be16c2c8-82ef-4f0f-9ebd-\
f5c0f288ca09"],

Cell[TextData[{
 "A ",
 StyleBox["new data structure",
  FontWeight->"Bold"],
 " is implemented to keep track of the position of replicates in the original \
data set. This also allows to share the whole dataset with each recursive \
call, so the whole dataset is returned at the end, partitioned in \
\[OpenCurlyDoubleQuote]inliers\[CloseCurlyDoubleQuote] and \
\[OpenCurlyDoubleQuote]outliers\[CloseCurlyDoubleQuote]."
}], "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.763391874882651*^9}, {
  3.763391922455335*^9, 3.763392069537795*^9}, {3.7633924434294577`*^9, 
  3.7633924556532803`*^9}},ExpressionUUID->"f9e473c5-3e72-45bc-8b20-\
5d77f53785fc"],

Cell[TextData[{
 "A ",
 StyleBox["new data output",
  FontWeight->"Bold"],
 " is included, in which data is formatted as associations (",
 StyleBox["output -> \[OpenCurlyDoubleQuote]Lists\[CloseCurlyDoubleQuote]",
  FontFamily->"Source Code Pro"],
 "), from which one can easily extract single sets, outliers, etc. See e.g. ",
 StyleBox["outlierPCA[data, output -> \[OpenCurlyDoubleQuote]Lists\
\[CloseCurlyDoubleQuote]][\[OpenCurlyDoubleQuote]Benzoate\
\[CloseCurlyDoubleQuote], \[OpenCurlyDoubleQuote]out\[CloseCurlyDoubleQuote]]",
  FontFamily->"Source Code Pro"],
 " that returns an association containing the outliers from the \
\[OpenCurlyDoubleQuote]Benzoate\[CloseCurlyDoubleQuote] labeled dataset, \
keyed with the respective replicate number from the original raw data set."
}], "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.763391874882651*^9}, {
  3.763391922455335*^9, 3.763392069537795*^9}, {3.7633924434294577`*^9, 
  3.763392577769096*^9}, {3.7633926270369825`*^9, 
  3.763392634073595*^9}},ExpressionUUID->"05a17ae5-850b-4e30-ab6d-\
4b5a8204f9b3"],

Cell[CellGroupData[{

Cell[TextData[{
 "By ",
 StyleBox["default",
  FontWeight->"Bold"],
 ", outlierPCA will do a single pass and return the plots; however, it can be \
set to recursive mode (the max number of recursive calls can also be set), \
and it can return a cleaned dataset."
}], "Item",
 CellChangeTimes->{{3.7633917234225836`*^9, 3.763391874882651*^9}, {
  3.763391922455335*^9, 
  3.7633921484859343`*^9}},ExpressionUUID->"70c2be87-d97b-4053-8512-\
69d15623e60b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"outlierPCA", "::", "dimcaution"}], "=", 
   "\"\<Using more than 3 dimensions for outlier detection may introduce too \
much noise\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"outlierPCA", "::", "highdims"}], "=", 
   "\"\<Dimensions requested are too high; limit to half the number of \
variables\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"outlierPCA", "::", "nonnumdims"}], "=", 
   "\"\<The value given for the dimensions option (`1`) was not recognized as \
an integer\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"outlierPCA", "::", "method"}], "=", 
   "\"\<An unrecognized method option (`1`) was used\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"outlierPCA", "::", "output"}], "=", 
    "\"\<An unrecognized output type was requested (`1`)\>\""}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"default", " ", "values", " ", "for", " ", "options"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "outlierPCA", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"dimensions", "\[Rule]", "2"}], ",", 
      RowBox[{"method", "\[Rule]", "\"\<SinglePass\>\""}], ",", 
      RowBox[{"output", "\[Rule]", "\"\<Plots\>\""}], ",", 
      RowBox[{"confidencelevel", "->", "0.95"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "function", " ", "definition", " ", "to", " ", "deal", " ", "with", " ", 
    "data", " ", "provided", " ", "as", " ", "lists", " ", 
    RowBox[{"(", "\"\<old standard format\>\"", ")"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "restructureData", " ", "returns", " ", "a", " ", "structured", " ", 
     "association"}], ",", " ", 
    RowBox[{
    "one", " ", "of", " ", "the", " ", "keys", " ", "being", " ", "the", " ", 
     "list", " ", "of", " ", "variable", " ", "names"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "that", " ", "part", " ", "is", " ", "dropped", " ", "here", " ", "before",
     " ", "passing", " ", "the", " ", "association", " ", "on"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"outlierPCA", "[", 
    RowBox[{
