Cell[CellGroupData[{

Cell["\<\
addLabels: helper function to re-add row and column labels to a numbers-only \
data set\
\>", "Section",
 CellChangeTimes->{{3.855940200773001*^9, 3.855940206359663*^9}, {
  3.8559403179897127`*^9, 
  3.8559403372939625`*^9}},ExpressionUUID->"20cf45aa-f89b-424d-b996-\
86e550c0037c"],

Cell[TextData[{
 "If ",
 StyleBox["no labels",
  FontWeight->"Bold"],
 " are provided, then generic \[OpenCurlyDoubleQuote]row_n\
\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]column_n\
\[CloseCurlyDoubleQuote] labels will be generated.\n\nIf ",
 StyleBox["only one set of labels",
  FontWeight->"Bold"],
 " is provided, then they will be assigned to the rows or columns depending \
on which dimension of data they fit. If there is no match, then the function \
should RETURN UNEVALUATED with an error.\n\nIf ",
 StyleBox["two sets of labels",
  FontWeight->"Bold"],
 " are given, the function will try to detect whether the labels are given in \
order of row then column, or column then row, based on the dimensions of the \
numbers matrix and of the label vectors. If no match can be found, then the \
function will return unevaluated with an error.\n\nIf the data matrix is \
square, both function definitions would apply, so the first one in the code \
below will match first, so the first set of labels will be assumed to be the \
rows. If another result is desired, one can swap the order of the labels in \
the function call."
}], "Text",
 CellChangeTimes->{{3.855940343454199*^9, 3.8559405224929633`*^9}, {
  3.8684584843466406`*^9, 
  3.868458661380503*^9}},ExpressionUUID->"7cc66b40-fc1c-4a89-ab2b-\
6107ef493624"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "addLabels", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"\"\<TopLeft\>\"", "->", "\"\<\>\""}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"addLabels", "::", "dims"}], "=", 
    "\"\<The dimensions of the labels provided do not match those of the data \
matrix.\>\""}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", 
     RowBox[{"==", " ", 
      RowBox[{"TWO", " ", "SETS"}]}], " ", "===", "===", "===", "===", 
     "==="}], "=", 
    RowBox[{"=", "=="}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"TWO", " ", 
     RowBox[{"SETS", ":", " ", 
      RowBox[{"Labels", " ", "given", " ", "as", " ", "rows"}]}]}], ",", " ", 
    RowBox[{"then", " ", "columns"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"For", " ", "square", " ", "m", " ", "matrices"}], ",", " ", 
    RowBox[{"this", " ", "will", " ", "match", " ", "first"}]}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"addLabels", "[", 
     RowBox[{
      RowBox[{"m_", "?", "MatrixQ"}], ",", "set1_", ",", "set2_", ",", 
      RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Length", "/@", 
       RowBox[{"{", 
        RowBox[{"set1", ",", "set2"}], "}"}]}], "==", 
      RowBox[{"Dimensions", "[", "m", "]"}]}], ")"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"List", "/@", 
      RowBox[{"Insert", "[", 
       RowBox[{"set1", ",", 
        RowBox[{"OptionValue", "[", "\"\<TopLeft\>\"", "]"}], ",", "1"}], 
       "]"}]}], ",", 
     RowBox[{"Insert", "[", 
      RowBox[{"m", ",", "set2", ",", "1"}], "]"}], ",", "2"}], "]"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"TWO", " ", 
     RowBox[{"SETS", ":", " ", 
      RowBox[{"Labels", " ", "given", " ", "as", " ", "columns"}]}]}], ",", 
    " ", 
    RowBox[{"then", " ", "rows"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"addLabels", "[", 
     RowBox[{
      RowBox[{"m_", "?", "MatrixQ"}], ",", "set1_", ",", "set2_", ",", 
      RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Length", "/@", 
       RowBox[{"{", 
        RowBox[{"set1", ",", "set2"}], "}"}]}], "==", 
      RowBox[{"Reverse", "@", 
       RowBox[{"Dimensions", "[", "m", "]"}]}]}], ")"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"List", "/@", 
      RowBox[{"Insert", "[", 
       RowBox[{"set2", ",", 
        RowBox[{"OptionValue", "[", "\"\<TopLeft\>\"", "]"}], ",", "1"}], 
       "]"}]}], ",", 
     RowBox[{"Insert", "[", 
      RowBox[{"m", ",", "set1", ",", "1"}], "]"}], ",", "2"}], "]"}]}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "==="}], "=", " ", 
    RowBox[{
     RowBox[{"END", " ", "TWO", " ", "SETS"}], " ", "===", "===", 
     RowBox[{"==", 
      RowBox[{"==", 
