   3.855230537246241*^9, 3.8552306953700037`*^9}, {3.8552307795140934`*^9, 
   3.8552307989147263`*^9}, 3.855230857620072*^9, 3.855230938210004*^9, {
   3.8552309695081797`*^9, 3.855231030282898*^9}, {3.855231090061578*^9, 
   3.8552311019710116`*^9}, {3.8552311413788767`*^9, 3.855231151173148*^9}, {
   3.8552312444272156`*^9, 3.8552313970082655`*^9}, {3.855231439525131*^9, 
