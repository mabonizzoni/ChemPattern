Cell[CellGroupData[{

Cell["\<\
projectorLDA: allows the projection of a second data set onto the LDA score \
plot generated  from the first one\
\>", "Section",
 CellChangeTimes->{{3.752422650090227*^9, 3.7524226872272835`*^9}, 
   3.8238969260517874`*^9},ExpressionUUID->"bf1f453c-ca0a-4027-8740-\
72c3df807c36"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "number", " ", "of", " ", "variables", " ", "in", " ", "the", 
    " ", "projector", " ", "and", " ", "projected", " ", "set", " ", "must", 
    " ", "be", " ", "the", " ", "same"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"projectorLDA", "::", "incompdims"}], "=", 
     "\"\<The number of variables (i.e. columns) in the two sets is not the \
same.\>\""}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Base", " ", "code"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"projectorLDA", "[", 
     RowBox[{
      RowBox[{"projectorSet_", "?", "ArrayQ"}], ",", "projectorSuffix_String",
       ",", 
      RowBox[{"projectedSet_", "?", "ArrayQ"}], ",", "projectedSuffix_String",
       ",", 
      RowBox[{"options", ":", 
       RowBox[{"OptionsPattern", "[", "lda", "]"}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
       "projectedScoresAsTable", ",", "projectedScoresAsAssociation", ",", 
        "\[IndentingNewLine]", "labelsForProjector", ",", 
        "labelsForProjected", ",", "projectorSetRelabeled"}], 
       "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Last", "@", 
           RowBox[{"Dimensions", "[", "projectorSet", "]"}]}], "\[NotEqual]", 
          RowBox[{"Last", "@", 
           RowBox[{"Dimensions", "[", "projectedSet", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{"Message", "[", 
           RowBox[{"projectorLDA", "::", "incompdims"}], "]"}], ";", 
          RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Extract", " ", "and", " ", "modify", " ", "labels", " ", "to", " ", 
         "add", " ", "suffixes"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"labelsForProjector", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"StringJoin", "[", 
           RowBox[{"#", ",", "projectorSuffix"}], "]"}], "&"}], "/@", 
         RowBox[{"projectorSet", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"2", ";;"}], ",", "1"}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"labelsForProjected", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"StringJoin", "[", 
           RowBox[{"#", ",", "projectedSuffix"}], "]"}], "&"}], "/@", 
         RowBox[{"projectedSet", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"2", ";;"}], ",", "1"}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Relabel", " ", "the", " ", "projector", " ", "set", " ", "with", " ",
          "the", " ", "new", " ", "labels", " ", "to", " ", "which", " ", 
         "the", " ", "requested", " ", "suffix", " ", "has", " ", "been", " ",
          "added"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"projectorSetRelabeled", "=", "projectorSet"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"projectorSetRelabeled", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"2", ";;"}], ",", "1"}], "]"}], "]"}], "=", 
        "labelsForProjector"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Calculate", " ", "n"}], "-", 
          RowBox[{"dimensional", " ", "scores"}]}], ",", " ", 
         RowBox[{
         "then", " ", "remove", " ", "adventitious", " ", "imaginary", " ", 
          "parts", " ", 
          RowBox[{"(", "Chop", ")"}]}], ",", " ", 
         RowBox[{
         "then", " ", "keep", " ", "only", " ", "first", " ", "two", " ", 
          "dimensions"}]}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"projectedScoresAsTable", "=", 
        RowBox[{
         RowBox[{"Chop", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Standardize", "[", " ", 
            RowBox[{"projectedSet", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"2", ";;"}], ",", 
               RowBox[{"2", ";;"}]}], "]"}], "]"}], " ", "]"}], ".", 
           RowBox[{"Transpose", "[", " ", 
            RowBox[{"lda", "[", 
             RowBox[{"projectorSetRelabeled", ",", 
              RowBox[{"output", "\[Rule]", "\"\<eigenvectors\>\""}]}], "]"}], 
            " ", "]"}]}], "\[IndentingNewLine]", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{";;", "2"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"projectedScoresAsAssociation", "=", 
        RowBox[{
         RowBox[{"GroupBy", "[", 
          RowBox[{"First", "\[Rule]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Tooltip", "[", 
              RowBox[{
               RowBox[{"Last", "[", "#", "]"}], ",", 
               RowBox[{"First", "[", "#", "]"}]}], "]"}], "&"}], ")"}]}], 
          "]"}], "@", 
         RowBox[{"Thread", "[", 
          RowBox[{"labelsForProjected", "\[Rule]", "projectedScoresAsTable"}],
           "]"}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Show", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "use", " ", "the", " ", "usual", " ", "LDA", " ", "function", " ", 
          "to", " ", "generate", " ", "a", " ", "base", " ", "plot"}], " ", 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "this", " ", "also", " ", "includes", " ", "the", " ", "usual", " ", 
          "formatting", " ", "and", " ", "factor", " ", "contribution", " ", 
          "calculations"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"lda", "[", 
          RowBox[{"projectorSetRelabeled", ",", 
           RowBox[{"output", "->", "\"\<2D\>\""}], ",", 
           RowBox[{"ellipsoidcolor", "\[Rule]", "True"}], ",", "options"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "generate", " ", "a", " ", "second", " ", "plot", " ", "from", " ", 
           "the", " ", "values"}], " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{"ListPlot", "[", 
          RowBox[{"Values", "@", "projectedScoresAsAssociation"}], "]"}]}], 
        "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Helper", " ", "argument", " ", "patterns", " ", "that", " ", "handle", 
     " ", "the", " ", "various", " ", "cases", " ", "of", " ", "missing", " ",
      "suffixes"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"projectorLDA", "[", 
     RowBox[{
      RowBox[{"projectorSet_", "?", "ArrayQ"}], ",", "projectorSuffix_String",
       ",", 
      RowBox[{"projectedSet_", "?", "ArrayQ"}], ",", 
      RowBox[{"options", ":", 
       RowBox[{"OptionsPattern", "[", "lda", "]"}]}]}], "]"}], ":=", 
    RowBox[{"projectorLDA", "[", 
     RowBox[{
     "projectorSet", ",", "projectorSuffix", ",", "projectedSet", ",", 
      "\"\<\>\"", ",", "options"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"projectorLDA", "[", 
     RowBox[{
      RowBox[{"projectorSet_", "?", "ArrayQ"}], ",", 
      RowBox[{"projectedSet_", "?", "ArrayQ"}], ",", "projectedSuffix_String",
       ",", 
      RowBox[{"options", ":", 
       RowBox[{"OptionsPattern", "[", "lda", "]"}]}]}], "]"}], ":=", 
    RowBox[{"projectorLDA", "[", 
     RowBox[{
     "projectorSet", ",", "\"\<\>\"", ",", "projectedSet", ",", 
      "projectedSuffix", ",", "options"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"projectorLDA", "[", 
     RowBox[{
      RowBox[{"projectorSet_", "?", "ArrayQ"}], ",", 
      RowBox[{"projectedSet_", "?", "ArrayQ"}], ",", 
      RowBox[{"options", ":", 
       RowBox[{"OptionsPattern", "[", "lda", "]"}]}]}], "]"}], ":=", 
    RowBox[{"projectorLDA", "[", 
     RowBox[{
     "projectorSet", ",", "\"\<\>\"", ",", "projectedSet", ",", "\"\<\>\"", 
      ",", "options"}], "]"}]}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7524227601354*^9, 3.752422828318512*^9}},
 CellLabel->
  "In[1039]:=",ExpressionUUID->"504e31af-e196-4be2-bcf8-5595a9c34eeb"]
