   3.763901865288123*^9, 3.763901868069928*^9}, {3.8238921570120115`*^9, 
   3.823892263475092*^9}, {3.8238923007255325`*^9, 3.823892310386451*^9}, {
   3.823892673630133*^9, 3.823892707111453*^9}, {3.823897792691757*^9, 
   3.8238980458995457`*^9}, {3.8238981014667435`*^9, 
   3.8238982168395615`*^9}, {3.823898263730437*^9, 3.8238982948243055`*^9}, {
   3.8238983429258795`*^9, 3.823898385924567*^9}, {3.823898463916144*^9, 
   3.8238984645566225`*^9}, {3.823898535731985*^9, 3.823898567555332*^9}, {
   3.823898691227719*^9, 3.8238986921766825`*^9}, {3.823898726268874*^9, 
   3.82389873335447*^9}, {3.823899591666199*^9, 3.8238995974796762`*^9}, {
   3.823899650982252*^9, 3.823899673862005*^9}, {3.8238997039947014`*^9, 
   3.8238997670225787`*^9}, {3.823899824975852*^9, 3.823899872280453*^9}, {
   3.8238999027250853`*^9, 3.8238999556727743`*^9}, {3.823900019511916*^9, 
   3.823900019777498*^9}, {3.823900063180884*^9, 3.823900063432846*^9}, {
   3.823900183605375*^9, 3.8239002096299334`*^9}, {3.8239002525967307`*^9, 
   3.8239003688363867`*^9}, {3.8239005151993265`*^9, 
   3.8239005200820885`*^9}, {3.8239005627675323`*^9, 
   3.8239005653897786`*^9}, {3.8239017233027015`*^9, 
   3.8239017351593986`*^9}, {3.842367391317562*^9, 3.8423674154708385`*^9}, {
