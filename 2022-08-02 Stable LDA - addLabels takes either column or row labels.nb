             RowBox[{"except", " ", "the", " ", "first", " ", "row"}], ",", 
             " ", 
             RowBox[{
             "which", " ", "are", " ", "measurement", " ", "labels", " ", 
              "and", " ", "should", " ", "not", " ", "be", " ", "touched"}]}],
             ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
          "1.", " ", "remove", " ", "first", " ", "row", " ", "and", " ", 
           "sort"}], ";", " ", 
          RowBox[{"2.", " ", "reattach", " ", "first", " ", "row"}], ";", " ", 
          RowBox[{"2.", " ", "remove", " ", "sample", " ", "labels"}]}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"data", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "}"}], "~", "Join", "~", 
           RowBox[{"SortBy", "[", 
            RowBox[{
             RowBox[{"data", "[", 
              RowBox[{"[", 
               RowBox[{"2", ";;"}], "]"}], "]"}], ",", 
             RowBox[{"{", "First", "}"}]}], "]"}]}], ")"}], "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{"2", ";;"}]}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"there", " ", "are", " ", "no", " ", "sample", " ", 
          RowBox[{"labels", ":", " ", 
           RowBox[{
           "nothing", " ", "needs", " ", "to", " ", "be", " ", "done"}]}]}], 
         "*)"}], "\[IndentingNewLine]", "data"}], "\[IndentingNewLine]", 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Build", " ", "sparklines", " ", "and", " ", "organize", " ", "them", 
       " ", "in", " ", "a", " ", "multicolumn", " ", "display"}], " ", "*)"}],
      "\[IndentingNewLine]", 
     RowBox[{"sparklines", "=", 
      RowBox[{"Multicolumn", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Framed", "[", "\[IndentingNewLine]", 
           RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"{", "##2", "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{"PlotLabel", "\[Rule]", 
              RowBox[{"Style", "[", 
               RowBox[{"#1", ",", "14", ",", "Red"}], "]"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"PlotRangePadding", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Scaled", "[", "0.03", "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"Scaled", "[", "0.05", "]"}], ",", 
                  RowBox[{"Scaled", "[", "0.1", "]"}]}], "}"}]}], "}"}]}], 
             ",", "\[IndentingNewLine]", 
             RowBox[{"Axes", "\[Rule]", "None"}], ",", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{
               "Do", " ", "not", " ", "display", " ", "a", " ", "frame", " ", 
                "around", " ", "the", " ", "plot", " ", 
                RowBox[{"area", ".", "\[IndentingNewLine]", "Although"}], " ",
                 "this", " ", "is", " ", "already", " ", "the", " ", 
                "default", " ", "for", " ", "ListPlot"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{
               "let", " ", "us", " ", "just", " ", "make", " ", "sure"}], ",",
                " ", 
               RowBox[{
               "in", " ", "case", " ", "the", " ", "default", " ", "has", " ",
                 "been", " ", "altered"}]}], "*)"}], "\[IndentingNewLine]", 
             RowBox[{"Frame", "\[Rule]", "None"}]}], "\[IndentingNewLine]", 
            "]"}], "\[IndentingNewLine]", "]"}], "&"}], "@@@", 
         RowBox[{"Transpose", "[", "workingdata", "]"}]}], ",", 
        "\[IndentingNewLine]", 
