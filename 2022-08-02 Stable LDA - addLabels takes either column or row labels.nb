Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "retainedInfo", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{"output", "\[Rule]", "\"\<Plot\>\""}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"retainedInfo", "[", 
    RowBox[{"dataset_", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "eigensystem", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"eigensystem", "=", 
       RowBox[{"lda", "[", 
        RowBox[{"dataset", ",", 
         RowBox[{"applyfunc", "\[Rule]", "Standardize"}], ",", 
         RowBox[{"output", "->", "\"\<eigensystem\>\""}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Switch", "[", 
       RowBox[{
        RowBox[{"OptionValue", "[", "output", "]"}], ",", 
        "\[IndentingNewLine]", "\"\<Plot\>\"", ",", 
        RowBox[{"iRetainedInfoPlot", "[", "eigensystem", "]"}], ",", 
        "\[IndentingNewLine]", "\"\<List\>\"", ",", 
        RowBox[{"iRetainedInfoList", "[", "eigensystem", "]"}], ",", 
        "\[IndentingNewLine]", "_", ",", 
        RowBox[{
         RowBox[{"Message", "[", 
          RowBox[{"retainedInfo", "::", "usage"}], "]"}], ";", 
         RowBox[{"Abort", "[", "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", "iRetainedInfo", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"iRetainedInfo", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"evals_", ",", "evecs_"}], "}"}], ",", "threshold_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "infolist", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"infolist", "=", 
       RowBox[{"100", 
        RowBox[{"Chop", "[", 
         RowBox[{
          RowBox[{"Normalize", "[", 
           RowBox[{"evals", ",", "Total"}], "]"}], ".", 
          RowBox[{"evecs", "^", "2"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Quantity", "[", 
       RowBox[{
        RowBox[{"Total", "@", 
         RowBox[{"Select", "[", 
          RowBox[{"infolist", ",", 
           RowBox[{
            RowBox[{"#", ">=", "threshold"}], "&"}]}], "]"}]}], ",", 
        "\"\<Percent\>\""}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", "iRetainedInfoPlot", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"iRetainedInfoPlot", "[", 
    RowBox[{"{", 
     RowBox[{"evals_", ",", "evecs_"}], "}"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "maxthreshold", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"maxthreshold", "=", 
       RowBox[{"Max", "[", 
        RowBox[{"100", 
         RowBox[{"Chop", "[", 
          RowBox[{
           RowBox[{"Normalize", "[", 
            RowBox[{"evals", ",", "Total"}], "]"}], ".", 
           RowBox[{"evecs", "^", "2"}]}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Plot", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"iRetainedInfo", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"evals", ",", "evecs"}], "}"}], ",", "t"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "maxthreshold"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"Automatic", ",", "100"}], "}"}]}], ",", 
        RowBox[{"PlotRangePadding", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Scaled", "[", "0.02", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", "2"}], "}"}]}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Axes", "\[Rule]", "False"}], ",", 
        RowBox[{"Frame", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"True", ",", "False"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"FrameTicks", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"Automatic", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"#", ",", 
               RowBox[{
                RowBox[{"ToString", "[", "#", "]"}], "<>", "\"\<%\>\""}]}], 
              "}"}], "&"}], "/@", 
            RowBox[{"Range", "[", 
             RowBox[{"0", ",", "100", ",", "20"}], "]"}]}]}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"FrameStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{"Black", ",", "14"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"FrameLabel", "\[Rule]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{"#", ",", "18"}], "]"}], "&"}], "/@", 
           RowBox[{"{", 
            RowBox[{
            "\"\<threshold to discard variables\>\"", ",", 
             "\"\<info retained in reduced system\>\""}], "}"}]}], ")"}]}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "\[IndentingNewLine]", 
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", "iRetainedInfoList", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iRetainedInfoList", "[", 
   RowBox[{"{", 
    RowBox[{"evals_", ",", "evecs_"}], "}"}], "]"}], ":=", 
  RowBox[{"With", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"maxthreshold", "=", 
      RowBox[{"Max", "[", 
       RowBox[{"100", 
        RowBox[{"Chop", "[", 
         RowBox[{
          RowBox[{"Normalize", "[", 
           RowBox[{"evals", ",", "Total"}], "]"}], ".", 
          RowBox[{"evecs", "^", "2"}]}], "]"}]}], "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"iRetainedInfo", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"evals", ",", "evecs"}], "}"}], ",", "t"}], "]"}]}], "}"}],
       ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "maxthreshold", ",", 
        RowBox[{"maxthreshold", "/", "200"}]}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7088757997025166`*^9, 3.708875907199665*^9}, {
