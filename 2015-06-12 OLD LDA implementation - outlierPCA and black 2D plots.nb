Cell[CellGroupData[{

Cell["Detection of outliers using PCA", "Section",
 CellChangeTimes->{{3.643117232420475*^9, 3.6431172448324924`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"outlierPCA", "[", "set_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "workingdata", ",", "eigenvectors", ",", "eigenvalues", ",", "PCs", ",", 
      "contributions"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"workingdata", "=", 
      RowBox[{"If", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"NumberQ", "[", 
         RowBox[{"set", "\[LeftDoubleBracket]", " ", 
          RowBox[{"1", ",", "2"}], "\[RightDoubleBracket]"}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"set", "\[LeftDoubleBracket]", 
         RowBox[{"All", ",", 
          RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}], ",", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "the", " ", "first", " ", "row", " ", "contains", " ", "data"}], 
          ",", " ", 
          RowBox[{"and", " ", "not", " ", "variable", " ", 
           RowBox[{"labels", ":", " ", 
            RowBox[{"do", " ", "not", " ", "discard", " ", 
             RowBox[{"it", "!"}]}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"set", "\[LeftDoubleBracket]", 
         RowBox[{
          RowBox[{"2", ";;"}], ",", 
          RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}]}], 
       RowBox[{"(*", " ", 
        RowBox[{
        "the", " ", "first", " ", "row", " ", "contains", " ", "variable", 
         " ", 
         RowBox[{"labels", ":", " ", 
          RowBox[{"discard", " ", "it"}]}]}], " ", "*)"}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eigenvalues", ",", "eigenvectors"}], "}"}], "=", 
      RowBox[{"Eigensystem", "@", 
       RowBox[{"Correlation", "@", "workingdata"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"PCs", "=", 
      RowBox[{
       RowBox[{"Standardize", "[", "workingdata", "]"}], ".", 
       RowBox[{"Transpose", "[", "eigenvectors", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"contributions", "=", 
      RowBox[{"Round", "[", 
       RowBox[{
        RowBox[{"100", 
         RowBox[{"Normalize", "[", 
          RowBox[{"eigenvalues", ",", "Total"}], "]"}]}], ",", "0.1"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"MapIndexed", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Labeled", "[", 
               RowBox[{"#1", ",", 
                RowBox[{"First", "@", "#2"}]}], "]"}], "&"}], ",", 
             RowBox[{"PCs", "\[LeftDoubleBracket]", 
              RowBox[{"All", ",", 
               RowBox[{"1", ";;", "2"}]}], "\[RightDoubleBracket]"}]}], "]"}],
            ",", "\[IndentingNewLine]", 
           RowBox[{"AspectRatio", "\[Rule]", "1"}], ",", 
           RowBox[{"PlotStyle", "\[Rule]", 
            RowBox[{"PointSize", "[", "0.02", "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Axes", "\[Rule]", "False"}], ",", 
           RowBox[{"Frame", "\[Rule]", "True"}], ",", 
           RowBox[{"FrameStyle", "\[Rule]", 
            RowBox[{"Directive", "[", 
             RowBox[{"Black", ",", 
              RowBox[{"FontSize", "\[Rule]", "14"}]}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"FrameLabel", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\"\<PC1 (\>\"", "<>", 
               RowBox[{"ToString", "[", 
                RowBox[{
                "contributions", "\[LeftDoubleBracket]", "1", 
                 "\[RightDoubleBracket]"}], "]"}], "<>", "\"\<%)\>\""}], ",", 
              RowBox[{"\"\<PC2 (\>\"", "<>", 
               RowBox[{"ToString", "[", 
                RowBox[{
                "contributions", "\[LeftDoubleBracket]", "2", 
                 "\[RightDoubleBracket]"}], "]"}], "<>", "\"\<%)\>\""}]}], 
             "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{"Epilog", "\[Rule]", 
            RowBox[{"Inset", "[", 
             RowBox[{
              RowBox[{"Style", "[", 
               RowBox[{
                RowBox[{"set", "\[LeftDoubleBracket]", 
                 RowBox[{"2", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
                "Red", ",", "Bold", ",", 
                RowBox[{"FontSize", "\[Rule]", "18"}]}], "]"}], ",", 
              RowBox[{"Scaled", "[", 
               RowBox[{"{", 
                RowBox[{"0.9", ",", "0.9"}], "}"}], "]"}]}], "]"}]}]}], 
          "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Graphics", "@", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Opacity", "[", "0", "]"}], ",", 
            RowBox[{"EdgeForm", "[", 
             RowBox[{"{", 
              RowBox[{"Gray", ",", "Dashed", ",", "Thick"}], "}"}], "]"}], 
            ",", 
            RowBox[{"Ellipsoid", "[", 
             RowBox[{
              RowBox[{"Mean", "@", 
               RowBox[{"PCs", "\[LeftDoubleBracket]", 
                RowBox[{"All", ",", 
                 RowBox[{"1", ";;", "2"}]}], "\[RightDoubleBracket]"}]}], ",", 
              RowBox[{"6", 
               RowBox[{"Covariance", "@", 
                RowBox[{"PCs", "\[LeftDoubleBracket]", 
                 RowBox[{"All", ",", 
                  RowBox[{"1", ";;", "2"}]}], "\[RightDoubleBracket]"}]}]}]}],
              "]"}]}], "}"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
       RowBox[{"PlotRangePadding", "\[Rule]", 
        RowBox[{"Scaled", "[", "0.1", "]"}]}]}], "\[IndentingNewLine]", 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.64311729288056*^9, 3.6431173628866587`*^9}, {
  3.6431174062137203`*^9, 3.6431174526007853`*^9}, {3.64311749131884*^9, 
  3.643117497059848*^9}, {3.643117609296006*^9, 3.6431178279273143`*^9}, {
  3.6431195787645607`*^9, 3.643119592260584*^9}, {3.6431199157439528`*^9, 
  3.6431199203615603`*^9}}]
}, Open  ]],

