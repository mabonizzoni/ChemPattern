        RowBox[{
         RowBox[{"Message", "[", 
          RowBox[{
           RowBox[{"lda", "::", "outputoptions"}], ",", 
           RowBox[{"OptionValue", "[", "output", "]"}]}], "]"}], ";", 
         RowBox[{"Return", "[", "]"}]}]}], "\[IndentingNewLine]", "]"}], 
