        RowBox[{"columnheaderlist", "."}]}]}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"if", " ", "not"}], ",", " ", 
       RowBox[{
       "create", " ", "a", " ", "generic", " ", "columnheaderlist", " ", 
        "and", " ", "add", " ", "it", " ", "to", " ", "the", " ", "top", " ", 
        "of", " ", "the", " ", "dataset"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "this", " ", "simplifies", " ", "manipulation", " ", "later", " ", "on",
        " ", "because", " ", "we", " ", "can", " ", "assume", " ", "the", " ",
        "presence", " ", "of", " ", "column", " ", "headers"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"and", " ", 
        RowBox[{"don", "'"}], "t", " ", "need", " ", "to", " ", "repeatedly", 
        " ", "check"}], ",", " ", 
       RowBox[{
       "no", " ", "matter", " ", "whether", " ", "the", " ", "original", " ", 
        "data", " ", "had", " ", "them", " ", "or", " ", "not"}]}], " ", 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Remember", " ", "that", " ", "from", " ", "now", " ", "on", " ", 
       RowBox[{"dataset", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], " ", "contains", " ", "no", 
       " ", "intereseting", " ", "data"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"VectorQ", "[", 
          RowBox[{
           RowBox[{"dataset", "\[LeftDoubleBracket]", 
            RowBox[{"1", ",", 
             RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}], ",", 
           "NumberQ"}], "]"}], "\[Equal]", "True"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"hascolumnheaders", "=", "False"}], ";", 
         RowBox[{
          RowBox[{"Prepend", "[", 
           RowBox[{"columnheaderlist", "=", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "\"\<\>\"", "}"}], ",", 
              RowBox[{"ToString", "/@", 
               RowBox[{"Array", "[", 
                RowBox[{"\"\<var\>\"", ",", 
                 RowBox[{
                  RowBox[{"Last", "@", 
                   RowBox[{"Dimensions", "@", "dataset"}]}], "-", "1"}]}], 
                "]"}]}]}], "]"}]}], "]"}], "[", "dataset", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"hascolumnheaders", "=", "True"}], ";", 
         RowBox[{"columnheaderlist", "=", 
          RowBox[{"dataset", "\[LeftDoubleBracket]", 
           RowBox[{"1", ",", 
            RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}]}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "extract", " ", "the", " ", "class", " ", "list", " ", "from", " ", 
         "the", " ", "first", " ", "column", " ", "in", " ", "the", " ", 
         "dataset"}], ";", " ", 
        RowBox[{
        "remember", " ", "that", " ", "the", " ", "first", " ", "row", " ", 
         "is", " ", "the", " ", "column", " ", "headers"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"classlist", "=", 
       RowBox[{"DeleteDuplicates", "[", 
        RowBox[{"dataset", "\[LeftDoubleBracket]", 
         RowBox[{
          RowBox[{"2", ";;"}], ",", "1"}], "\[RightDoubleBracket]"}], "]"}]}],
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Apply", " ", "the", " ", "applyfunc", " ", "function", " ", "to", " ",
         "the", " ", "numerical", " ", "part", " ", "of", " ", "the", " ", 
        "dataaset"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"applyfunction", "'"}], "s", " ", "default", " ", "is", " ", 
         "Identity"}], ",", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"i", ".", "e", ".", " ", "do"}], " ", "nothing"}], ";", " ", 
         RowBox[{"if", " ", "standardization", " ", "is", " ", "desired"}]}], 
        ","}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "an", " ", "appropriate", " ", "standardizing", " ", "function", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"e", ".", "g", ".", " ", "Standardize"}], " ", "itself"}], 
         ")"}], " ", "can", " ", "be", " ", "passed", " ", "in"}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"dataset", "\[LeftDoubleBracket]", 
        RowBox[{
         RowBox[{"2", ";;"}], ",", 
         RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}], "=", 
       RowBox[{
        RowBox[{"OptionValue", "[", "applyfunc", "]"}], "[", 
        RowBox[{"dataset", "\[LeftDoubleBracket]", 
         RowBox[{
          RowBox[{"2", ";;"}], ",", 
          RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "Row", " ", "headers", " ", "are", " ", "used", " ", "as", " ", 
         "class", " ", "labels", " ", "to", " ", "partition", " ", "the", " ",
          "data", " ", "into", " ", "the", " ", "user"}], "-", 
        RowBox[{"specified", " ", "classes"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "The", " ", "first", " ", "row", " ", "of", " ", "dataset", " ", 
        "contains", " ", "the", " ", "column", " ", "headers", " ", "so", " ",
         "it", " ", "is", " ", "ignored", " ", "here"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "The", " ", "class", " ", "labels", " ", "are", " ", "then", " ", 
        "removed", " ", "before", " ", "assigning", " ", "the", " ", "list", 
        " ", "of", " ", "partitioned", " ", "datasets", " ", "to", " ", 
        "partitioneddata"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"partitioneddata", "=", 
       RowBox[{
        RowBox[{"GatherBy", "[", 
         RowBox[{
          RowBox[{"dataset", "\[LeftDoubleBracket]", 
           RowBox[{"2", ";;"}], "\[RightDoubleBracket]"}], ",", "First"}], 
         "]"}], "\[LeftDoubleBracket]", 
        RowBox[{"All", ",", "All", ",", 
         RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Calculate", " ", "the", " ", "within"}], "-", 
         RowBox[{
         "cluster", " ", "scatter", " ", "by", " ", "applying", " ", "the", 
          " ", "Swi", " ", "function", " ", "to", " ", "each", " ", 
          "cluster"}]}], ",", " ", 
        RowBox[{"and", " ", "summing", " ", "up", " ", "each", " ", 
         RowBox[{"cluster", "'"}], "s", " ", "contribution"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Swi", "[", "set_", "]"}], ":=", 
       RowBox[{"Total", "[", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"#", "-", 
               RowBox[{"Mean", "[", "set", "]"}]}], "}"}], "]"}], ".", 
            RowBox[{"{", 
             RowBox[{"#", "-", 
              RowBox[{"Mean", "[", "set", "]"}]}], "}"}]}], "&"}], ",", 
          "set"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Sw", "=", 
       RowBox[{"Total", "[", 
        RowBox[{"Map", "[", 
         RowBox[{"Swi", ",", "partitioneddata"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"Calculate", " ", "the", " ", "between"}], "-", 
        RowBox[{"cluster", " ", "scatter"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "In", " ", "the", " ", "case", " ", "of", " ", "a", " ", 
         "standardized", " ", "dataset"}], ",", " ", 
        RowBox[{"the", " ", "grand", " ", "mean"}], ",", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"i", ".", "e", ".", " ", "the"}], " ", "column"}], "-", 
         RowBox[{
         "wise", " ", "mean", " ", "over", " ", "the", " ", "entire", " ", 
          "dataset", " ", "should", " ", "be", " ", "exactly", " ", 
          "zero"}]}]}], " ", "*)"}], 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
         RowBox[{
         "However", " ", "it", " ", "will", " ", "typically", " ", 
          "calculate", " ", "out", " ", "to", " ", "very", " ", "small", " ", 
          "non"}], "-", 
         RowBox[{"zero", " ", "numbers", " ", "at", " ", "machine", " ", 
          RowBox[{"precision", ".", " ", "To"}], " ", "avoid", " ", 
          "accumulating", " ", "inaccuracies"}]}], ","}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"the", " ", "grand", " ", "mean", " ", "is", " ", 
         RowBox[{"chopped", ".", " ", "If"}], " ", "the", " ", "dataset", " ",
          "is", " ", "not", " ", "standardized"}], ",", " ", 
        RowBox[{
        "chopping", " ", "has", " ", "no", " ", "significant", " ", 
         "effect"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"grandmean", "=", 
       RowBox[{"Chop", "@", 
        RowBox[{"Mean", "[", 
         RowBox[{"dataset", "\[LeftDoubleBracket]", 
          RowBox[{
           RowBox[{"2", ";;"}], ",", 
           RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"clustermeans", "=", 
       RowBox[{"Map", "[", 
        RowBox[{"Mean", ",", "partitioneddata"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Sb", "=", 
       RowBox[{"Total", "[", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"Transpose", "[", 
              RowBox[{"{", 
               RowBox[{"#", "-", "grandmean"}], "}"}], "]"}], ".", 
             RowBox[{"{", 
              RowBox[{"#", "-", "grandmean"}], "}"}]}], "&"}], ")"}], ",", 
          "clustermeans"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Maximize", " ", "the", " ", 
        RowBox[{"Sb", "/", "Sw"}], " ", "ratio", " ", "by", " ", "solving", 
        " ", "the", " ", "equivalent", " ", "eigenproblem"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"The", " ", 
         RowBox[{"Check", "[", "]"}], " ", "wrapper", " ", "around", " ", 
         "Inverse", " ", "stops", " ", "computation", " ", "and", " ", 
         "returns", " ", "if", " ", "the", " ", "inverse", " ", "cannot", " ",
          "be", " ", "computed"}], ",", " ", 
        RowBox[{
         RowBox[{"e", ".", "g", ".", " ", "for"}], " ", "singular", " ", 
         "matrices"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eigenvals", ",", "eigenvecs"}], "}"}], "=", 
       RowBox[{"Chop", "@", 
        RowBox[{"Eigensystem", "[", 
         RowBox[{"Check", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Inverse", "[", "Sw", "]"}], ".", "Sb"}], ",", 
           RowBox[{"Abort", "[", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"Inverse", "::", "sing"}], "}"}]}], "]"}], "]"}]}]}], ";",
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculate", " ", "data", " ", "scores", " ", "along", " ", "the", " ",
         "LDA", " ", "dimensions"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"transformeddata", "=", 
