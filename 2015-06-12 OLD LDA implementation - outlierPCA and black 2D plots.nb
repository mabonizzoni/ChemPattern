  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "alternative", " ", "definition", " ", "of", " ", "lda", " ", 
    "handles", " ", "malformed", " ", "input"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lda", "::", "notamatrix"}], "=", 
   "\"\<The input to lda is not a matrix.\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lda", "[", 
    RowBox[{
     RowBox[{"dataset_", "/;", 
      RowBox[{"Not", "[", 
       RowBox[{"MatrixQ", "[", "dataset", "]"}], "]"}]}], ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Message", "[", 
    RowBox[{"lda", "::", "notamatrix"}], "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "following", " ", "function", " ", "generates", " ", "a", " ", 
    "bar", " ", "chart", " ", "of", " ", "the", " ", "weighted", " ", 
    "contributions", " ", "of", " ", "each", " ", "sensor", " ", "to", " ", 
    "the", " ", "overall", " ", "discrimination"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "The", " ", "contributions", " ", "are", " ", "weighted", " ", "by", " ", 
     "the", " ", "weight", " ", "of", " ", "the", " ", "factors", " ", 
     "themselves"}], ",", " ", 
    RowBox[{
    "represented", " ", "by", " ", "the", " ", "eigenvalues", " ", "from", 
     " ", "lda"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "because", " ", "a", " ", "sensor", " ", "that", 
    " ", "contributes", " ", "a", " ", "lot", " ", "to", " ", "an", " ", 
    "unimportant", " ", "factor", " ", "is", " ", "still", " ", "unimportant",
     " ", "in", " ", "the", " ", "overall", " ", "discrimination"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Remove", "[", "groupcontribs", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"groupcontribs", "::", "usage"}], "=", 
   "\"\<groupcontribs[eigensystem,numberofgroups,sensornames]\\\
ngroupedcontributions[eigensystem,numberofgroups]\\nThe function generates a \
bar chart of the contributions of each group of variables to the overall \
discrimination. Before summing, the contributions to each factor are weighted \
by the corresponding eigenvalue of the factor. This is needed so that a group \
that contributes a lot to an unimportant factor is still reported as \
unimportant in the overall discrimination.\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"groupcontribs", "::", "numgroups"}], "=", 
    "\"\<The number of variables in the eigensystem (`1`) is not an exact \
multiple of the number of groups provided (`2`).\>\""}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"groupcontribs", "[", 
   RowBox[{"eigensystem_", ",", "numberofgroups_", ",", 
    RowBox[{"sensornames_:", "Null"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"eigenvals", "=", 
       RowBox[{
       "eigensystem", "\[LeftDoubleBracket]", "1", 
        "\[RightDoubleBracket]"}]}], ",", 
      RowBox[{"eigenvecs", "=", 
       RowBox[{
       "eigensystem", "\[LeftDoubleBracket]", "2", 
        "\[RightDoubleBracket]"}]}], ",", "variablespergroup", ",", 
      "sqweightedeigenvecs", ",", "barvalues"}], "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"Length", "@", "eigenvecs"}], ",", "numberofgroups"}], 
         "]"}], "\[Equal]", "0"}], ",", "\[IndentingNewLine]", 
       RowBox[{"variablespergroup", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Length", "@", "eigenvecs"}], ")"}], "/", 
         "numberofgroups"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{
          RowBox[{"groupcontribs", "::", "numgroups"}], ",", 
          RowBox[{"Length", "@", "eigenvecs"}], ",", "numberofgroups"}], 
         "]"}], ";", 
        RowBox[{"Abort", "[", "]"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "eigenvectors", " ", "are", " ", "weighted", " ", "by", " ", "the", 
        " ", "corresponding", " ", "eigenvalues"}], ",", " ", 
       RowBox[{"then", " ", "squared"}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"sqweightedeigenvecs", "=", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Normalize", "[", 
          RowBox[{"eigenvals", ",", "Total"}], "]"}], "eigenvecs"}], ")"}], 
       "2"]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"barvalues", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Round", "[", 
           RowBox[{
            RowBox[{"100", "#"}], ",", "1"}], "]"}], "&"}], "@", 
         "\[IndentingNewLine]", 
         RowBox[{"Normalize", "[", 
          RowBox[{"#", ",", "Total"}], "]"}]}], "&"}], "@", 
       "\[IndentingNewLine]", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Chop", "@", 
          RowBox[{"Total", "[", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"sqweightedeigenvecs", "\[LeftDoubleBracket]", 
              RowBox[{"All", ",", 
               RowBox[{"i", ";;", 
                RowBox[{"variablespergroup", "-", "1", "+", "i"}]}]}], 
              "\[RightDoubleBracket]"}], "2"], ",", "Infinity"}], "]"}]}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{
            RowBox[{"Last", "@", 
             RowBox[{"Dimensions", "@", "eigenvecs"}]}], "-", 
            "variablespergroup", "+", "1"}], ",", "variablespergroup"}], 
          "}"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"BarChart", "[", "\[IndentingNewLine]", 
      RowBox[{"barvalues", ",", "\[IndentingNewLine]", 
       RowBox[{"ChartLabels", "\[Rule]", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"#", ",", 
             RowBox[{"FontSize", "\[Rule]", "20"}], ",", "Black"}], "]"}], 
           "&"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"sensornames", "===", "Null"}], ",", 
            RowBox[{"Array", "[", 
             RowBox[{"group", ",", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"Last", "@", 
                 RowBox[{"Dimensions", "@", "eigenvecs"}]}], ")"}], "/", 
               "variablespergroup"}]}], "]"}], ",", "sensornames"}], "]"}]}], 
         "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"BarSpacing", "\[Rule]", "Large"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotLabel", "\[Rule]", 
        RowBox[{"Style", "[", 
         RowBox[{
         "\"\<% contribution of each sensor (overall)\>\"", ",", "Black", ",", 
          RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
          RowBox[{"FontSize", "\[Rule]", "20"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "\[Rule]", 
        RowBox[{"Scaled", "[", "0.25", "]"}]}]}], "\[IndentingNewLine]", 
      "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}], "\[IndentingNewLine]"}], "Input",
